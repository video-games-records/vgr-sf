parameters:
    level: 8
    paths:
        - src
        - tests
    excludePaths:
        - var
        - vendor
        - tests/bootstrap.php
        # Exclude Sonata Admin classes (dynamic configuration causes PHPStan issues)
        - src/BoundedContext/*/Presentation/Admin/*Admin.php
        - src/BoundedContext/*/Infrastructure/Admin/Extension/*Extension.php

