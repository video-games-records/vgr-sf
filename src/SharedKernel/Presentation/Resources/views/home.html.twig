{% extends 'base.html.twig' %}

{% block title %}Home - Video Games Records{% endblock %}

{% block body %}
{# Hero Header Content - Hidden on mobile #}
<div class="d-none d-md-block mb-4">
    <div class="row">
        <div class="col-md-8 col-lg-6">
            <p class="text-muted mb-2">
                Video Games Records is a video game records website, created in 2003. You can enter the competition and challenge hundreds of players on a wide choice of games, available on a significant number of platforms.
            </p>
            <p class="text-muted mb-0">
                Our <strong>5,311 members</strong> have posted <strong>1,598,941 records</strong> on <strong>5,994 games</strong>.
            </p>
        </div>
    </div>
</div>

{# Top 5 Leaderboards Section #}
<div class="row g-4">
    {# Game Points Leaderboard #}
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card border shadow-sm h-100">
            <div class="card-header border-bottom">
                <h5 class="mb-0"><i class="bi bi-graph-up-arrow"></i> Game Points</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th class="text-center" style="width: 50px;">#</th>
                                <th>Player</th>
                                <th class="text-end">Points</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-center"><span class="badge rounded-pill bg-warning text-dark">1</span></td>
                                <td><strong>Basile</strong></td>
                                <td class="text-end">2,782,254</td>
                            </tr>
                            <tr>
                                <td class="text-center"><span class="badge rounded-pill bg-secondary">2</span></td>
                                <td>narutokyuby</td>
                                <td class="text-end">2,192,235</td>
                            </tr>
                            <tr>
                                <td class="text-center"><span class="badge rounded-pill bg-secondary">3</span></td>
                                <td>daftpunk</td>
                                <td class="text-end">2,184,677</td>
