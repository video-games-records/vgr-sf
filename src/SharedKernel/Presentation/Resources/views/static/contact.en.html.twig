{% extends 'base.html.twig' %}

{% block title %}Contact Us - VGR{% endblock %}

{% block meta_description %}Multiple ways to reach us and get help. Our team is here to assist you.{% endblock %}

{% block body %}
<div class="container py-5">
    {# Header #}
    <div class="text-center mb-5">
        <div class="d-flex justify-content-center mb-3">
            <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                <i class="bi bi-envelope-fill h1 text-primary mb-0"></i>
            </div>
        </div>
        <h1 class="display-4 fw-bold mb-3">Contact Us</h1>
        <p class="lead text-muted mx-auto" style="max-width: 800px;">
            Multiple ways to reach us and get help. Our team is here to assist you with any questions or support you need.
        </p>
    </div>

    {# Main Contact Methods #}
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="row g-4 mb-5">
                {# Email General #}
                <div class="col-md-6">
                    <div class="card h-100 border-2 shadow-sm">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-4">
                                <div class="bg-primary bg-opacity-10 rounded-3 p-3 me-3">
                                    <i class="bi bi-envelope-fill h3 text-primary mb-0"></i>
                                </div>
                                <div>
                                    <h3 class="h5 mb-1">General Email</h3>
                                    <p class="text-muted small mb-0">For all your questions</p>
                                </div>
                            </div>

                            <div class="bg-light rounded-3 p-3 mb-4">
                                <div class="d-flex gap-2 mb-2">
                                    <span class="badge bg-secondary">Contact</span>
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success">● Available</span>
                                </div>
                                <p class="font-monospace small bg-white p-3 rounded border border-2 border-dashed mb-0">
                                    contact@videogamesrecords.net
                                </p>
                            </div>

                            <p class="small text-muted mb-3">General questions, suggestions, feedback</p>
                            <div class="d-flex align-items-center gap-2 text-muted small mb-4">
                                <i class="bi bi-clock"></i>
                                <span>24-48h average</span>
                            </div>

                            <a href="mailto:contact@videogamesrecords.net" class="btn btn-primary">
                                <i class="bi bi-envelope me-2"></i>Send email
                            </a>
                        </div>
                    </div>
                </div>

                {# Discord Server #}
                <div class="col-md-6">
                    <div class="card h-100 border-2 shadow-sm">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-4">
                                <div class="bg-primary bg-opacity-10 rounded-3 p-3 me-3" style="background-color: rgba(128, 0, 128, 0.1) !important;">
                                    <i class="bi bi-chat-dots-fill h3 mb-0" style="color: purple;"></i>
                                </div>
                                <div>
                                    <h3 class="h5 mb-1">Discord Server</h3>
                                    <p class="text-muted small mb-0">Community and quick support</p>
                                </div>
                            </div>

                            <div class="bg-light rounded-3 p-3 mb-4">
                                <div class="d-flex gap-2 mb-2">
                                    <span class="badge bg-secondary">Contact</span>
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success">● Available</span>
                                </div>
                                <p class="font-monospace small bg-white p-3 rounded border border-2 border-dashed mb-0">
                                    discord.gg/xh5QqaMzqm
                                </p>
                            </div>

                            <p class="small text-muted mb-3">Real-time chat, community help</p>
                            <div class="d-flex align-items-center gap-2 text-muted small mb-4">
                                <i class="bi bi-clock"></i>
                                <span>Immediate (when available)</span>
                            </div>

                            <a href="https://discord.gg/xh5QqaMzqm" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                                <i class="bi bi-chat-dots me-2"></i>Join Discord
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            {# Specialized Contacts #}
            <div class="card mb-5 border-2">
                <div class="card-header bg-primary bg-opacity-10">
                    <h2 class="h5 mb-0">
                        <i class="bi bi-person me-2"></i>
                        Specialized Contacts
                    </h2>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        {# Technical Support #}
                        <div class="col-sm-6 col-lg-3">
                            <div class="border border-2 rounded-3 p-4 h-100 text-center">
                                <div class="bg-primary bg-opacity-10 rounded-3 p-3 d-inline-block mb-3">
                                    <i class="bi bi-bug-fill h4 text-primary mb-0"></i>
                                </div>
                                <h4 class="h6 fw-bold mb-2">Technical Support</h4>
                                <p class="small text-muted mb-3">Bugs, technical issues, malfunctions</p>
                                <a href="mailto:support@videogamesrecords.net" class="small text-primary text-decoration-none font-monospace">
                                    support@videogamesrecords.net
                                </a>
                            </div>
                        </div>

                        {# Data Protection #}
                        <div class="col-sm-6 col-lg-3">
                            <div class="border border-2 rounded-3 p-4 h-100 text-center">
                                <div class="bg-primary bg-opacity-10 rounded-3 p-3 d-inline-block mb-3">
                                    <i class="bi bi-shield-fill-check h4 text-primary mb-0"></i>
                                </div>
                                <h4 class="h6 fw-bold mb-2">Data Protection</h4>
                                <p class="small text-muted mb-3">GDPR, privacy, data deletion</p>
                                <a href="mailto:dpo@videogamesrecords.net" class="small text-primary text-decoration-none font-monospace">
                                    dpo@videogamesrecords.net
                                </a>
                            </div>
                        </div>

                        {# Suggestions & Ideas #}
                        <div class="col-sm-6 col-lg-3">
                            <div class="border border-2 rounded-3 p-4 h-100 text-center">
                                <div class="bg-primary bg-opacity-10 rounded-3 p-3 d-inline-block mb-3">
                                    <i class="bi bi-lightbulb-fill h4 text-primary mb-0"></i>
                                </div>
                                <h4 class="h6 fw-bold mb-2">Suggestions & Ideas</h4>
                                <p class="small text-muted mb-3">New features, improvements</p>
                                <a href="mailto:ideas@videogamesrecords.net" class="small text-primary text-decoration-none font-monospace">
                                    ideas@videogamesrecords.net
                                </a>
                            </div>
                        </div>

                        {# Partnerships #}
                        <div class="col-sm-6 col-lg-3">
                            <div class="border border-2 rounded-3 p-4 h-100 text-center">
                                <div class="bg-primary bg-opacity-10 rounded-3 p-3 d-inline-block mb-3">
                                    <i class="bi bi-briefcase-fill h4 text-primary mb-0"></i>
                                </div>
                                <h4 class="h6 fw-bold mb-2">Partnerships</h4>
                                <p class="small text-muted mb-3">Collaborations, partnerships, opportunities</p>
                                <a href="mailto:business@videogamesrecords.net" class="small text-primary text-decoration-none font-monospace">
                                    business@videogamesrecords.net
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {# Additional Info #}
            <div class="row g-4 mb-5">
                {# Support Hours #}
                <div class="col-lg-4">
                    <div class="card border-2 h-100">
                        <div class="card-header">
                            <h3 class="h6 mb-0">
                                <i class="bi bi-clock me-2"></i>
                                Support Hours
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="border-bottom py-3">
                                <div class="d-flex justify-content-between">
                                    <span class="fw-medium small">Monday - Friday</span>
                                    <span class="text-muted small">9:00 AM - 6:00 PM</span>
                                </div>
                            </div>
                            <div class="border-bottom py-3">
                                <div class="d-flex justify-content-between">
                                    <span class="fw-medium small">Weekend</span>
                                    <span class="text-muted small">Limited support</span>
                                </div>
                            </div>
                            <div class="py-3">
                                <div class="d-flex justify-content-between">
                                    <span class="fw-medium small">Discord</span>
                                    <span class="text-muted small">24/7 (community)</span>
                                </div>
                            </div>
                            <div class="alert alert-warning mt-3 mb-0">
                                <p class="small mb-0">
                                    <strong>Note:</strong> Responses may take longer on weekends and holidays.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                {# Response Times #}
                <div class="col-lg-4">
                    <div class="card border-2 h-100">
                        <div class="card-header">
                            <h3 class="h6 mb-0">
                                <i class="bi bi-chat-dots me-2"></i>
                                Response Times
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="bg-success bg-opacity-10 border border-success rounded-3 p-3 mb-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-success rounded-circle" style="width: 12px; height: 12px;"></div>
                                        <span class="fw-medium small">Discord</span>
                                    </div>
                                    <span class="text-muted small">Real time</span>
                                </div>
                            </div>

                            <div class="bg-primary bg-opacity-10 border border-primary rounded-3 p-3 mb-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-primary rounded-circle" style="width: 12px; height: 12px;"></div>
                                        <span class="fw-medium small">General email</span>
                                    </div>
                                    <span class="text-muted small">24-48h</span>
                                </div>
                            </div>

                            <div class="bg-warning bg-opacity-10 border border-warning rounded-3 p-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-warning rounded-circle" style="width: 12px; height: 12px;"></div>
                                        <span class="fw-medium small">Technical support</span>
                                    </div>
                                    <span class="text-muted small">2-5 days</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                {# Quick Help #}
                <div class="col-lg-4">
                    <div class="card border-2 h-100">
                        <div class="card-header">
                            <h3 class="h6 mb-0">
                                <i class="bi bi-lightbulb me-2"></i>
                                Quick Help
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                                <h4 class="fw-bold small mb-2">Before contacting us</h4>
                                <ul class="small text-muted mb-0 ps-3">
                                    <li>Check our FAQ section</li>
                                    <li>Search existing forum topics</li>
                                    <li>Try Discord for quick answers</li>
                                    <li>Include details in your message</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {# Footer #}
            <div class="card border-2">
                <div class="card-body text-center py-5">
                    <div class="bg-primary bg-opacity-10 rounded-circle p-4 d-inline-block mb-4">
                        <i class="bi bi-chat-dots-fill display-4 text-primary"></i>
                    </div>
                    <h3 class="h5 fw-bold mb-3">We're here to help</h3>
                    <p class="text-muted mb-4 mx-auto" style="max-width: 600px;">
                        Don't hesitate to contact us for any question, suggestion or problem.
                        Our dedicated team is ready to assist you and ensure you have the best experience possible!
                    </p>
                    <div class="d-flex flex-wrap justify-content-center gap-2">
                        <span class="badge bg-secondary">English Support</span>
                        <span class="badge bg-secondary">Active Community</span>
                        <span class="badge bg-secondary">Quick Response</span>
                        <span class="badge bg-secondary">Professional Service</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
