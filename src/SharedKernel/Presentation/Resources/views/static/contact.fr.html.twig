{% extends '@SharedKernel/base.html.twig' %}

{% block title %}Nous Contacter - VGR{% endblock %}

{% block meta_description %}Plusieurs moyens pour nous joindre et obtenir de l'aide. Notre équipe est là pour vous accompagner.{% endblock %}

{% block body %}
<div class="container py-5">
    {# Header #}
    <div class="text-center mb-5">
        <div class="d-flex justify-content-center mb-3">
            <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                <i class="bi bi-envelope-fill h1 text-primary mb-0"></i>
            </div>
        </div>
        <h1 class="display-4 fw-bold mb-3">Nous Contacter</h1>
        <p class="lead text-muted mx-auto" style="max-width: 800px;">
            Plusieurs moyens pour nous joindre et obtenir de l'aide. Notre équipe est là pour vous accompagner dans toutes vos questions ou besoins de support.
        </p>
    </div>

    {# Main Contact Methods #}
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="row g-4 mb-5">
                {# Email Général #}
                <div class="col-md-6">
                    <div class="card h-100 border-2 shadow-sm">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-4">
                                <div class="bg-primary bg-opacity-10 rounded-3 p-3 me-3">
                                    <i class="bi bi-envelope-fill h3 text-primary mb-0"></i>
                                </div>
                                <div>
                                    <h3 class="h5 mb-1">Email Général</h3>
                                    <p class="text-muted small mb-0">Pour toutes vos questions</p>
                                </div>
                            </div>

                            <div class="bg-light rounded-3 p-3 mb-4">
                                <div class="d-flex gap-2 mb-2">
                                    <span class="badge bg-secondary">Contact</span>
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success">● Disponible</span>
                                </div>
                                <p class="font-monospace small bg-white p-3 rounded border border-2 border-dashed mb-0">
                                    contact@videogamesrecords.net
                                </p>
                            </div>

                            <p class="small text-muted mb-3">Questions générales, suggestions, feedback</p>
                            <div class="d-flex align-items-center gap-2 text-muted small mb-4">
                                <i class="bi bi-clock"></i>
                                <span>24-48h en moyenne</span>
                            </div>

                            <a href="mailto:contact@videogamesrecords.net" class="btn btn-primary">
                                <i class="bi bi-envelope me-2"></i>Envoyer un email
                            </a>
                        </div>
                    </div>
                </div>

                {# Serveur Discord #}
                <div class="col-md-6">
                    <div class="card h-100 border-2 shadow-sm">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-4">
                                <div class="bg-primary bg-opacity-10 rounded-3 p-3 me-3" style="background-color: rgba(128, 0, 128, 0.1) !important;">
                                    <i class="bi bi-chat-dots-fill h3 mb-0" style="color: purple;"></i>
                                </div>
                                <div>
                                    <h3 class="h5 mb-1">Serveur Discord</h3>
                                    <p class="text-muted small mb-0">Communauté et support rapide</p>
                                </div>
                            </div>

                            <div class="bg-light rounded-3 p-3 mb-4">
                                <div class="d-flex gap-2 mb-2">
                                    <span class="badge bg-secondary">Contact</span>
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success">● Disponible</span>
                                </div>
                                <p class="font-monospace small bg-white p-3 rounded border border-2 border-dashed mb-0">
                                    discord.gg/xh5QqaMzqm
                                </p>
                            </div>

                            <p class="small text-muted mb-3">Chat en temps réel, entraide communautaire</p>
                            <div class="d-flex align-items-center gap-2 text-muted small mb-4">
                                <i class="bi bi-clock"></i>
                                <span>Immédiat (selon disponibilité)</span>
                            </div>

                            <a href="https://discord.gg/xh5QqaMzqm" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                                <i class="bi bi-chat-dots me-2"></i>Rejoindre Discord
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            {# Contacts Spécialisés #}
            <div class="card mb-5 border-2">
                <div class="card-header bg-primary bg-opacity-10">
                    <h2 class="h5 mb-0">
                        <i class="bi bi-person me-2"></i>
                        Contacts Spécialisés
                    </h2>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        {# Support Technique #}
                        <div class="col-sm-6 col-lg-3">
                            <div class="border border-2 rounded-3 p-4 h-100 text-center">
                                <div class="bg-primary bg-opacity-10 rounded-3 p-3 d-inline-block mb-3">
                                    <i class="bi bi-bug-fill h4 text-primary mb-0"></i>
                                </div>
                                <h4 class="h6 fw-bold mb-2">Support Technique</h4>
                                <p class="small text-muted mb-3">Bugs, problèmes techniques, dysfonctionnements</p>
                                <a href="mailto:support@videogamesrecords.net" class="small text-primary text-decoration-none font-monospace">
                                    support@videogamesrecords.net
                                </a>
                            </div>
                        </div>

                        {# Protection des Données #}
                        <div class="col-sm-6 col-lg-3">
                            <div class="border border-2 rounded-3 p-4 h-100 text-center">
                                <div class="bg-primary bg-opacity-10 rounded-3 p-3 d-inline-block mb-3">
                                    <i class="bi bi-shield-fill-check h4 text-primary mb-0"></i>
                                </div>
                                <h4 class="h6 fw-bold mb-2">Protection des Données</h4>
                                <p class="small text-muted mb-3">RGPD, vie privée, suppression de données</p>
                                <a href="mailto:dpo@videogamesrecords.net" class="small text-primary text-decoration-none font-monospace">
                                    dpo@videogamesrecords.net
                                </a>
                            </div>
                        </div>

                        {# Suggestions & Idées #}
                        <div class="col-sm-6 col-lg-3">
                            <div class="border border-2 rounded-3 p-4 h-100 text-center">
                                <div class="bg-primary bg-opacity-10 rounded-3 p-3 d-inline-block mb-3">
                                    <i class="bi bi-lightbulb-fill h4 text-primary mb-0"></i>
                                </div>
                                <h4 class="h6 fw-bold mb-2">Suggestions & Idées</h4>
                                <p class="small text-muted mb-3">Nouvelles fonctionnalités, améliorations</p>
                                <a href="mailto:ideas@videogamesrecords.net" class="small text-primary text-decoration-none font-monospace">
                                    ideas@videogamesrecords.net
                                </a>
                            </div>
                        </div>

                        {# Partenariats #}
                        <div class="col-sm-6 col-lg-3">
                            <div class="border border-2 rounded-3 p-4 h-100 text-center">
                                <div class="bg-primary bg-opacity-10 rounded-3 p-3 d-inline-block mb-3">
                                    <i class="bi bi-briefcase-fill h4 text-primary mb-0"></i>
                                </div>
                                <h4 class="h6 fw-bold mb-2">Partenariats</h4>
                                <p class="small text-muted mb-3">Collaborations, partenariats, opportunités</p>
                                <a href="mailto:business@videogamesrecords.net" class="small text-primary text-decoration-none font-monospace">
                                    business@videogamesrecords.net
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {# Additional Info #}
            <div class="row g-4 mb-5">
                {# Horaires de Support #}
                <div class="col-lg-4">
                    <div class="card border-2 h-100">
                        <div class="card-header">
                            <h3 class="h6 mb-0">
                                <i class="bi bi-clock me-2"></i>
                                Horaires de Support
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="border-bottom py-3">
                                <div class="d-flex justify-content-between">
                                    <span class="fw-medium small">Lundi - Vendredi</span>
                                    <span class="text-muted small">9h00 - 18h00</span>
                                </div>
                            </div>
                            <div class="border-bottom py-3">
                                <div class="d-flex justify-content-between">
                                    <span class="fw-medium small">Week-end</span>
                                    <span class="text-muted small">Support limité</span>
                                </div>
                            </div>
                            <div class="py-3">
                                <div class="d-flex justify-content-between">
                                    <span class="fw-medium small">Discord</span>
                                    <span class="text-muted small">24h/24 (communauté)</span>
                                </div>
                            </div>
                            <div class="alert alert-warning mt-3 mb-0">
                                <p class="small mb-0">
                                    <strong>Note :</strong> Les réponses peuvent prendre plus de temps le week-end et les jours fériés.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                {# Temps de Réponse #}
                <div class="col-lg-4">
                    <div class="card border-2 h-100">
                        <div class="card-header">
                            <h3 class="h6 mb-0">
                                <i class="bi bi-chat-dots me-2"></i>
                                Temps de Réponse
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="bg-success bg-opacity-10 border border-success rounded-3 p-3 mb-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-success rounded-circle" style="width: 12px; height: 12px;"></div>
                                        <span class="fw-medium small">Discord</span>
                                    </div>
                                    <span class="text-muted small">Temps réel</span>
                                </div>
                            </div>

                            <div class="bg-primary bg-opacity-10 border border-primary rounded-3 p-3 mb-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-primary rounded-circle" style="width: 12px; height: 12px;"></div>
                                        <span class="fw-medium small">Email général</span>
                                    </div>
                                    <span class="text-muted small">24-48h</span>
                                </div>
                            </div>

                            <div class="bg-warning bg-opacity-10 border border-warning rounded-3 p-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-warning rounded-circle" style="width: 12px; height: 12px;"></div>
                                        <span class="fw-medium small">Support technique</span>
                                    </div>
                                    <span class="text-muted small">2-5 jours</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                {# Aide Rapide #}
                <div class="col-lg-4">
                    <div class="card border-2 h-100">
                        <div class="card-header">
                            <h3 class="h6 mb-0">
                                <i class="bi bi-lightbulb me-2"></i>
                                Aide Rapide
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                                <h4 class="fw-bold small mb-2">Avant de nous contacter</h4>
                                <ul class="small text-muted mb-0 ps-3">
                                    <li>Consultez notre section FAQ</li>
                                    <li>Recherchez dans les sujets existants du forum</li>
                                    <li>Essayez Discord pour des réponses rapides</li>
                                    <li>Incluez des détails dans votre message</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {# Footer #}
            <div class="card border-2">
                <div class="card-body text-center py-5">
                    <div class="bg-primary bg-opacity-10 rounded-circle p-4 d-inline-block mb-4">
                        <i class="bi bi-chat-dots-fill display-4 text-primary"></i>
                    </div>
                    <h3 class="h5 fw-bold mb-3">Nous sommes là pour vous aider</h3>
                    <p class="text-muted mb-4 mx-auto" style="max-width: 600px;">
                        N'hésitez pas à nous contacter pour toute question, suggestion ou problème.
                        Notre équipe dédiée est prête à vous accompagner et à vous garantir la meilleure expérience possible !
                    </p>
                    <div class="d-flex flex-wrap justify-content-center gap-2">
                        <span class="badge bg-secondary">Support Francophone</span>
                        <span class="badge bg-secondary">Communauté Active</span>
                        <span class="badge bg-secondary">Réponse Rapide</span>
                        <span class="badge bg-secondary">Service Professionnel</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
