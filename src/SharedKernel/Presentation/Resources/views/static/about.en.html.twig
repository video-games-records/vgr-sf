{% extends '@SharedKernel/base.html.twig' %}

{% block title %}About Us - VGR{% endblock %}

{% block meta_description %}Discover the story, mission, and team behind Video Games Records{% endblock %}

{% block body %}
<div class="container py-5">
    {# Header #}
    <div class="text-center mb-5">
        <div class="d-flex justify-content-center mb-3">
            <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                <i class="bi bi-heart-fill h1 text-primary mb-0"></i>
            </div>
        </div>
        <h1 class="display-4 fw-bold mb-3">About Us</h1>
        <p class="lead text-muted mx-auto" style="max-width: 600px;">
            Discover the story, mission, and team behind this platform that brings together a passionate community around video game excellence.
        </p>
    </div>

    {# Mission, Story, Values #}
    <div class="row justify-content-center mb-5">
        <div class="col-lg-10">
            <div class="row g-4 mb-5">
                {# Mission #}
                <div class="col-md-4">
                    <div class="card h-100 border-2">
                        <div class="card-header bg-primary bg-opacity-10">
                            <h2 class="h5 mb-0">
                                <i class="bi bi-bullseye me-2"></i>
                                Our Mission
                            </h2>
                        </div>
                        <div class="card-body">
                            <p>Create the global reference for video game records by bringing together a passionate community around gaming excellence.</p>
                            <p>We provide a platform where every player can immortalize their achievements, share their strategies, and celebrate exceptional performances that push the boundaries of what's possible.</p>
                        </div>
                    </div>
                </div>

                {# Story #}
                <div class="col-md-4">
                    <div class="card h-100 border-2">
                        <div class="card-header bg-danger bg-opacity-10">
                            <h2 class="h5 mb-0">
                                <i class="bi bi-heart-fill me-2"></i>
                                Our Story
                            </h2>
                        </div>
                        <div class="card-body">
                            <p>Founded in 2003 by magicbart, Video Games Records was born from the frustration of seeing so many extraordinary achievements fade into oblivion.</p>
                            <p>What started as a personal project quickly transformed into a collective adventure thanks to the enthusiasm of our growing community.</p>
                        </div>
                    </div>
                </div>

                {# Values #}
                <div class="col-md-4">
                    <div class="card h-100 border-2">
                        <div class="card-header bg-success bg-opacity-10">
                            <h2 class="h5 mb-0">
                                <i class="bi bi-shield-check me-2"></i>
                                Our Values
                            </h2>
                        </div>
                        <div class="card-body">
                            <p>Our core values guide every decision we make:</p>
                            <ul class="mb-0">
                                <li><strong>Authenticity:</strong> Every record is rigorously verified</li>
                                <li><strong>Inclusivity:</strong> All players deserve recognition</li>
                                <li><strong>Passion:</strong> Love of video games guides us</li>
                                <li><strong>Community:</strong> Together we build gaming history</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            {# Statistics #}
