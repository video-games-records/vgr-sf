                    </div>
                </div>
            </div>

            {# Footer #}
            <div class="card">
                <div class="card-body text-center py-5">
                    <i class="bi bi-check-circle-fill text-success display-4 mb-3"></i>
                    <h3 class="h5 fw-bold mb-3">Responsible Usage</h3>
                    <p class="text-muted mb-4">
                        By respecting these terms, you help maintain a healthy and respectful community for everyone.
                    </p>
                    <div class="d-flex flex-column flex-sm-row justify-content-center align-items-center gap-3 small">
                        <span class="text-muted">
                            <strong>Version effective since:</strong> August 30, 2025
                        </span>
                        <span class="d-none d-sm-inline text-muted">•</span>
                        <a href="{{ path('static_rules') }}" class="fw-bold text-decoration-none">
