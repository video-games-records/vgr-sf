{% extends 'base.html.twig' %}

{% block title %}Terms of Service - VGR{% endblock %}

{% block meta_description %}The rules that govern the use of our platform{% endblock %}

{% block body %}
<div class="container py-5">
    {# Header #}
    <div class="text-center mb-5">
        <div class="d-flex justify-content-center mb-3">
            <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                <i class="bi bi-file-text-fill h1 text-primary mb-0"></i>
            </div>
        </div>
        <h1 class="display-4 fw-bold mb-3">Terms of Service</h1>
        <p class="lead text-muted">
            The rules that govern the use of our platform
        </p>
