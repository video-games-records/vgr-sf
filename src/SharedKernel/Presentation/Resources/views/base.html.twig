{% trans_default_domain 'SharedKernel' %}
<!DOCTYPE html>
<html lang="{{ app.request.locale }}" data-bs-theme="light">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Video Games Records{% endblock %}</title>

        {# SEO Meta Tags #}
        <meta name="description" content="{% block meta_description %}World Crash Rankings - The ultimate resource for Burnout 3: Takedown Crash Mode rankings, player statistics, zone records, and competitive leaderboards.{% endblock %}">
        <meta name="keywords" content="{% block meta_keywords %}burnout 3, crash mode, rankings, leaderboards, world records{% endblock %}">
        <meta name="robots" content="{% block meta_robots %}index, follow{% endblock %}">

        {# Canonical URL #}
        <link rel="canonical" href="{% block canonical_url %}{{ app.request.schemeAndHttpHost ~ app.request.baseUrl ~ app.request.pathInfo }}{% endblock %}">

        {# Open Graph Meta Tags #}
        <meta property="og:site_name" content="World Crash Rankings">
        <meta property="og:title" content="{% block og_title %}{{ block('title') }}{% endblock %}">
        <meta property="og:description" content="{% block og_description %}{{ block('meta_description') }}{% endblock %}">
        <meta property="og:type" content="{% block og_type %}website{% endblock %}">
        <meta property="og:url" content="{% block og_url %}{{ block('canonical_url') }}{% endblock %}">
        <meta property="og:image" content="{% block og_image %}{{ absolute_url(asset('img/banner.png')) }}{% endblock %}">

        {# Twitter Card Meta Tags #}
        <meta name="twitter:card" content="{% block twitter_card %}summary_large_image{% endblock %}">
        <meta name="twitter:title" content="{% block twitter_title %}{{ block('og_title') }}{% endblock %}">
        <meta name="twitter:description" content="{% block twitter_description %}{{ block('og_description') }}{% endblock %}">
        <meta name="twitter:image" content="{% block twitter_image %}{{ block('og_image') }}{% endblock %}">

        {# Sitemap and Performance #}
        <link rel="sitemap" type="application/xml" title="Sitemap" href="{{ asset('sitemap.xml') }}">
        <link rel="dns-prefetch" href="//cdn.jsdelivr.net">

        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🎮</text></svg>">

        {# Google Analytics - Production only #}
        {% if app.environment == 'prod' %}
            <script async src="https://www.googletagmanager.com/gtag/js?id="></script>
            <script>
                window.dataLayer = window.dataLayer || [];
                function gtag(){dataLayer.push(arguments);}
                gtag('js', new Date());
                gtag('config', '');
            </script>
        {% endif %}

        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}

        {# JSON-LD Structured Data #}
        {% block structured_data %}{% endblock %}
    </head>
    <body>
        {# Navigation #}
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="{{ path('home') }}">
                    <img src="{{ asset('img/logo/video-games-records-logo.png') }}" alt="Video Games Records" height="40">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('home') }}">{{ 'navigation.home'|trans }}</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="gamesDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                {{ 'navigation.games'|trans }}
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="gamesDropdown">
                                <li><a class="dropdown-item" href="{{ path('vgr_game_list_by_letter', {letter: 'a'}) }}"><i class="bi bi-alphabet"></i> {{ 'navigation.games_dropdown.by_letter'|trans }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('vgr_platform_index') }}"><i class="bi bi-controller"></i> {{ 'navigation.games_dropdown.by_platform'|trans }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('vgr_serie_index') }}"><i class="bi bi-collection"></i> {{ 'navigation.games_dropdown.by_series'|trans }}</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-star"></i> {{ 'navigation.games_dropdown.featured_games'|trans }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('vgr_game_list_latest') }}"><i class="bi bi-clock-history"></i> {{ 'navigation.games_dropdown.latest_games'|trans }}</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="leaderboardsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                {{ 'navigation.leaderboards'|trans }}
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="leaderboardsDropdown">
                                <li><a class="dropdown-item" href="{{ path('leaderboard_point_games') }}"><i class="bi bi-graph-up-arrow"></i> {{ 'navigation.leaderboards_dropdown.game_points'|trans }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('leaderboard_point_charts') }}"><i class="bi bi-bar-chart-line"></i> {{ 'navigation.leaderboards_dropdown.record_points'|trans }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('leaderboard_medals') }}"><i class="bi bi-award"></i> {{ 'navigation.leaderboards_dropdown.medals'|trans }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('leaderboard_cups') }}"><i class="bi bi-trophy"></i> {{ 'navigation.leaderboards_dropdown.cups'|trans }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('leaderboard_badges') }}"><i class="bi bi-patch-check"></i> {{ 'navigation.leaderboards_dropdown.badges'|trans }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('leaderboard_proofs') }}"><i class="bi bi-camera-video"></i> {{ 'navigation.leaderboards_dropdown.proofs'|trans }}</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-flag"></i> {{ 'navigation.leaderboards_dropdown.country'|trans }}</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="communityDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                {{ 'navigation.community'|trans }}
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="communityDropdown">
                                <li><a class="dropdown-item" href="#"><i class="bi bi-chat-dots"></i> {{ 'navigation.community_dropdown.forum'|trans }}</a></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-person"></i> {{ 'navigation.community_dropdown.players'|trans }}</a></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-people"></i> {{ 'navigation.community_dropdown.teams'|trans }}</a></li>
                            </ul>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        {# Language Switcher #}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="languageDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                {% if app.request.locale == 'fr' %}
                                    🇫🇷 FR
                                {% else %}
                                    🇬🇧 EN
                                {% endif %}
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="languageDropdown">
                                <li>
                                    <a class="dropdown-item {{ app.request.locale == 'en' ? 'active' : '' }}"
                                       href="{{ path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')|merge({'_locale': 'en'})) }}">
                                        🇬🇧 {{ 'navigation.language.english'|trans }}
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item {{ app.request.locale == 'fr' ? 'active' : '' }}"
                                       href="{{ path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')|merge({'_locale': 'fr'})) }}">
                                        🇫🇷 {{ 'navigation.language.french'|trans }}
                                    </a>
                                </li>
                            </ul>
                        </li>

                        {# Theme Toggle #}
                        <li class="nav-item">
                            <button class="nav-link btn btn-link" id="theme-toggle" onclick="toggleTheme()" aria-label="{{ 'theme.toggle'|trans }}">
                                <i class="bi bi-moon-fill"></i>
                            </button>
                        </li>

                        {% if app.user %}
                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SONATA_ADMIN') %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('sonata_admin_dashboard') }}" data-turbo-prefetch="false">
                                        <i class="bi bi-speedometer2"></i> {{ 'navigation.admin'|trans }}
                                    </a>
                                </li>
                            {% endif %}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="user-badge">{{ app.user.username }}</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" href="{{ path('app_profile_index') }}">{{ 'navigation.user_menu.profile'|trans }}</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_profile_index') }}">{{ 'navigation.user_menu.settings'|trans }}</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="{{ path('app_logout') }}">{{ 'navigation.user_menu.logout'|trans }}</a></li>
                                </ul>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link btn btn-primary text-white px-3" href="{{ path('app_login') }}" data-turbo="false" data-turbo-prefetch="false">{{ 'navigation.login'|trans }}</a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        {# Site Header with background image (V7 style) - Image only, no content #}
        <div class="site-header d-none d-md-block"></div>

        {# Flash Messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="container mt-3">
                    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                        {{ message|trans }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                </div>
            {% endfor %}
        {% endfor %}

        {# Main Content #}
        <main class="container-fluid py-4">
            {% block body %}{% endblock %}
        </main>

        {# Footer #}
        <footer class="py-4 mt-5">
            <div class="container">
                <div class="row">
                    <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                        <p class="mb-0">&copy; {{ 'now'|date('Y') }} {{ 'footer.copyright'|trans }}</p>
                    </div>
                    <div class="col-md-6 text-center text-md-end">
                        <a href="{{ path('static_faq') }}" class="me-2"><i class="bi bi-question-circle"></i> {{ 'footer.links.faq'|trans }}</a>
                        <a href="{{ path('static_rules') }}" class="me-2"><i class="bi bi-shield-check"></i> {{ 'footer.links.rules'|trans }}</a>
                        <a href="{{ path('static_privacy') }}" class="me-2"><i class="bi bi-eye"></i> {{ 'footer.links.privacy'|trans }}</a>
                        <a href="{{ path('static_terms') }}" class="me-2"><i class="bi bi-file-text"></i> {{ 'footer.links.terms'|trans }}</a>
                        <a href="{{ path('static_contact') }}" class="me-2"><i class="bi bi-envelope"></i> {{ 'footer.links.contact'|trans }}</a>
                        <a href="{{ path('static_about') }}" class="me-2"><i class="bi bi-info-circle"></i> {{ 'footer.links.about'|trans }}</a>
                        <a href="#"><i class="bi bi-scale"></i> {{ 'footer.links.legal'|trans }}</a>
                    </div>
                </div>
            </div>
        </footer>
    </body>
</html>
