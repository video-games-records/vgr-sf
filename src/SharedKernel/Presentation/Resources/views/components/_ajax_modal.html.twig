{# Reusable AJAX Modal Component #}
<div id="ajaxModal" class="ajax-modal" style="display: none;">
    <div class="ajax-modal-dialog">
        <div class="ajax-modal-content">
            <div class="ajax-modal-body text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        </div>
    </div>
</div>
