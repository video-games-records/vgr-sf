{# ============================================================
 # Theme Picker – Offcanvas Bootstrap 5
 # Triggered by: data-bs-toggle="offcanvas" data-bs-target="#themePicker"
 # ============================================================ #}
<div class="offcanvas offcanvas-end" tabindex="-1" id="themePicker" aria-labelledby="themePickerLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="themePickerLabel">
            <i class="bi bi-palette me-2"></i>Choisir un thème
