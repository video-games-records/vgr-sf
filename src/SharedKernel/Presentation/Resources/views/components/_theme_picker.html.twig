            <button class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-2"
                    data-vgr-theme="light" onclick="applyTheme('light')">
                <span class="theme-swatch" style="background:#f8f9fa;border:1px solid #dee2e6"></span>Light
            </button>
            <button class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-2"
