{% extends '@SharedKernel/base.html.twig' %}

{% block title %}{{ status_code }} - Error - Video Games Records{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6 text-center">
            <div class="mb-4">
                <img src="{{ asset('img/logo/video-games-records-logo.png') }}" alt="Video Games Records" height="60" class="mb-4">
            </div>

            <h1 class="display-1 fw-bold text-danger">{{ status_code }}</h1>
            <h2 class="h3 mb-3">An error occurred</h2>
            <p class="text-muted mb-4">
                Something went wrong. Please try again later.
            </p>

            <a href="{{ path('home') }}" class="btn btn-primary btn-lg">
                <i class="bi bi-house me-2"></i>Back to home
            </a>
        </div>
    </div>
</div>
{% endblock %}
