{% extends '@SharedKernel/base.html.twig' %}

{% trans_default_domain 'Article' %}

{% block title %}{{ translation ? translation.title : article.defaultTitle }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-4 p-md-5">
                    <article>
                        <header class="mb-4 pb-3 border-bottom">
                            <h1 class="h2 mb-3">
                                {{ translation ? translation.title : article.defaultTitle }}
                            </h1>

                            <div class="text-muted small">
                                <div class="d-flex flex-wrap gap-3 align-items-center">
                                    {% if article.author %}
                                        <span>
                                            <i class="bi bi-person-circle me-1"></i>
                                            {{ article.author.username }}
                                        </span>
                                    {% endif %}

                                    {% if article.publishedAt %}
                                        <span>
                                            <i class="bi bi-calendar3 me-1"></i>
                                            <time datetime="{{ article.publishedAt|date('Y-m-d') }}">
                                                {{ article.publishedAt|date('F j, Y') }}
                                            </time>
                                        </span>
                                    {% endif %}

                                    <span>
                                        <i class="bi bi-eye me-1"></i>
                                        {{ article.views }} views
                                    </span>

                                    <span>
                                        <i class="bi bi-chat-dots me-1"></i>
                                        <a href="#comments" class="text-decoration-none text-muted">
                                            {{ 'comment.count'|trans({'%count%': totalComments}) }}
                                        </a>
                                    </span>
                                </div>
                            </div>
                        </header>

                        <div class="mb-5">
                            {{ translation ? translation.content|raw : article.defaultContent|raw }}
                        </div>

                        <div class="mt-5">
                            <a href="{{ path('home') }}" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Back to articles
                            </a>
                        </div>
                    </article>
                </div>
            </div>

            {# Comments section #}
            <div class="mt-5" id="comments">
                <h3 class="mb-4">
                    <i class="bi bi-chat-dots me-2"></i>{{ 'comment.section_title'|trans({'%count%': totalComments}) }}
                </h3>

                {% for flashMessage in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle"></i> {{ flashMessage }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}

                {% for flashMessage in app.flashes('danger') %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-circle"></i> {{ flashMessage }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}

                {% include '@Article/article/_pagination.html.twig' with {
                    route: 'article_show',
                    routeParams: {id: article.id, slug: article.slug},
                    currentPage: currentPage,
                    totalPages: totalPages,
                    totalItems: totalComments,
                    perPage: 10
                } %}

                {% for comment in comments %}
                    <div class="card mb-3" id="comment-{{ comment.id }}" data-controller="comment-edit">
                        <div class="card-header d-flex justify-content-between align-items-center py-2">
                            <div class="d-flex align-items-center gap-2">
                                <a href="{{ path('vgr_player_profile_overview', {id: comment.user.id, slug: comment.user.slug}) }}">
                                    <img src="/users/{{ comment.user.id }}/avatar"
                                         alt="{{ comment.user.username }}"
                                         class="rounded-circle"
                                         width="32" height="32">
                                </a>
                                <a href="{{ path('vgr_player_profile_overview', {id: comment.user.id, slug: comment.user.slug}) }}" class="text-decoration-none fw-bold">
                                    {{ comment.user.username }}
                                </a>
                                <small class="text-muted">
                                    <i class="bi bi-clock"></i> {{ comment.createdAt|date('d/m/Y H:i') }}
                                </small>
                                {% if comment.updatedAt > comment.createdAt %}
                                    <small class="text-muted fst-italic">
                                        ({{ 'comment.edited'|trans }})
                                    </small>
                                {% endif %}
                            </div>
                            {% if app.user and app.user.id == comment.user.id %}
                                <button type="button" class="btn btn-sm btn-outline-secondary" data-action="comment-edit#toggle">
                                    <i class="bi bi-pencil"></i> {{ 'comment.edit'|trans }}
                                </button>
                            {% endif %}
                        </div>
                        <div class="card-body">
                            {# Display mode #}
                            <div data-comment-edit-target="display">
                                {{ comment.content|raw }}
                            </div>

                            {# Edit mode #}
                            {% if app.user and app.user.id == comment.user.id and editForms[comment.id] is defined %}
                                <div class="d-none" data-comment-edit-target="form">
                                    {{ form_start(editForms[comment.id]) }}
                                        <div class="mb-3">
                                            {{ form_widget(editForms[comment.id].content, {'value': comment.content}) }}
                                            {{ form_errors(editForms[comment.id].content) }}
                                        </div>
                                        <div class="d-flex justify-content-end gap-2">
                                            <button type="button" class="btn btn-secondary" data-action="comment-edit#toggle">
                                                {{ 'comment.cancel'|trans }}
                                            </button>
                                            <button type="submit" class="btn btn-primary">
                                                <i class="bi bi-check-lg"></i> {{ 'comment.update'|trans }}
                                            </button>
                                        </div>
                                    {{ form_end(editForms[comment.id]) }}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% else %}
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> {{ 'comment.no_comments'|trans }}
                    </div>
                {% endfor %}

                {% include '@Article/article/_pagination.html.twig' with {
                    route: 'article_show',
                    routeParams: {id: article.id, slug: article.slug},
                    currentPage: currentPage,
                    totalPages: totalPages,
                    totalItems: totalComments,
                    perPage: 10
                } %}

                {# Add comment form #}
                {% if commentForm %}
                    <div class="card mt-4" id="add-comment">
                        <div class="card-header py-3">
                            <h5 class="mb-0">
                                <i class="bi bi-reply"></i> {{ 'comment.add_title'|trans }}
                            </h5>
                        </div>
                        <div class="card-body">
                            {{ form_start(commentForm) }}
                                <div class="mb-3">
                                    {{ form_label(commentForm.content) }}
                                    {{ form_widget(commentForm.content) }}
                                    {{ form_errors(commentForm.content) }}
                                </div>
                                <div class="d-flex justify-content-end">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-send"></i> {{ 'comment.submit'|trans }}
                                    </button>
                                </div>
                            {{ form_end(commentForm) }}
                        </div>
                    </div>
                {% else %}
                    <div class="alert alert-info mt-4">
                        <i class="bi bi-info-circle"></i> {{ 'comment.login_required'|trans }}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
