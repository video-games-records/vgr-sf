{% extends '@SharedKernel/base.html.twig' %}

{% block title %}{{ translation ? translation.title : article.defaultTitle }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-4 p-md-5">
                    <article>
                        <header class="mb-4 pb-3 border-bottom">
                            <h1 class="h2 mb-3">
                                {{ translation ? translation.title : article.defaultTitle }}
                            </h1>

                            <div class="text-muted small">
                                <div class="d-flex flex-wrap gap-3 align-items-center">
                                    {% if article.author %}
                                        <span>
                                            <i class="bi bi-person-circle me-1"></i>
                                            {{ article.author.username }}
                                        </span>
                                    {% endif %}

                                    {% if article.publishedAt %}
                                        <span>
                                            <i class="bi bi-calendar3 me-1"></i>
                                            <time datetime="{{ article.publishedAt|date('Y-m-d') }}">
                                                {{ article.publishedAt|date('F j, Y') }}
                                            </time>
                                        </span>
                                    {% endif %}

                                    <span>
                                        <i class="bi bi-eye me-1"></i>
                                        {{ article.views }} views
                                    </span>
                                </div>
                            </div>
                        </header>

                        <div class="mb-5">
                            {{ translation ? translation.content|raw : article.defaultContent|raw }}
                        </div>

                        <div class="mt-5">
                            <a href="{{ path('home') }}" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Back to articles
                            </a>
                        </div>
                    </article>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
