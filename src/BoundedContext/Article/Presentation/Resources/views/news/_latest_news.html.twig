<div class="card border shadow-sm h-100">
    <div class="card-header border-bottom">
        <h5 class="mb-0"><i class="bi bi-newspaper"></i> {{ 'news.latest_news'|trans({}, 'Article') }}</h5>
    </div>
    <div class="card-body p-0">
        <div class="list-group list-group-flush">
            {% for article in articles %}
                <a href="{{ path('article_show', {id: article.id, slug: article.slug}) }}" class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <span class="text-truncate me-2">{{ article.title }}</span>
                        <small class="text-muted text-nowrap">{{ article.publishedAt|date('M d') }}</small>
                    </div>
                </a>
            {% else %}
                <div class="list-group-item text-center text-muted py-4">
                    {{ 'news.no_news'|trans({}, 'Article') }}
                </div>
            {% endfor %}
        </div>
    </div>
</div>
