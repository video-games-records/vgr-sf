{% extends '@SharedKernel/base.html.twig' %}

{% trans_default_domain 'Forum' %}

{% block title %}{{ 'forum.title'|trans }} - {{ parent() }}{% endblock %}

{% block body %}
    <div class="container">
        <h1 class="mb-4">{{ 'forum.title'|trans }}</h1>

        <ul class="nav nav-tabs mb-4" id="forumTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="categories-tab" data-bs-toggle="tab" data-bs-target="#categories" type="button" role="tab" aria-controls="categories" aria-selected="true">
                    <i class="bi bi-folder"></i> {{ 'forum.tabs.categories'|trans }}
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="recent-tab" data-bs-toggle="tab" data-bs-target="#recent" type="button" role="tab" aria-controls="recent" aria-selected="false">
                    <i class="bi bi-clock-history"></i> {{ 'forum.tabs.recent'|trans }}
                    {% if recentTopics|length > 0 %}
                        <span class="badge bg-primary">{{ recentTopics|length }}</span>
                    {% endif %}
                </button>
            </li>
        </ul>

        <div class="tab-content" id="forumTabsContent">
            <div class="tab-pane fade show active" id="categories" role="tabpanel" aria-labelledby="categories-tab">
                {% for category in categories %}
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0">{{ category.name }}</h5>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>{{ 'forum.table.forum'|trans }}</th>
                                        <th class="text-center d-none d-sm-table-cell" style="width: 80px;">{{ 'forum.table.topics'|trans }}</th>
                                        <th class="text-center d-none d-sm-table-cell" style="width: 80px;">{{ 'forum.table.messages'|trans }}</th>
                                        <th class="d-none d-md-table-cell" style="width: 220px;">{{ 'forum.table.last_message'|trans }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for forum in category.forums %}
                                        <tr>
                                            <td>
                                                <i class="bi bi-chat-left-text me-2"></i>
                                                <a href="{{ path('forum_show', {id: forum.id, slug: forum.slug}) }}" class="text-decoration-none">
                                                    <strong>
                                                        {% if app.request.locale == 'fr' and forum.libForumFr %}
                                                            {{ forum.libForumFr }}
                                                        {% else %}
                                                            {{ forum.libForum }}
                                                        {% endif %}
                                                    </strong>
                                                </a>
                                            </td>
                                            <td class="text-center d-none d-sm-table-cell">{{ forum.nbTopic }}</td>
                                            <td class="text-center d-none d-sm-table-cell">{{ forum.nbMessage }}</td>
                                            <td class="d-none d-md-table-cell">
                                                {% if forum.lastMessage %}
                                                    <small class="text-muted">
                                                        {{ forum.lastMessage.createdAt|date('d/m/Y H:i') }}<br>
                                                        {{ 'forum.by'|trans }}
                                                        <a href="{{ path('vgr_player_profile_overview', {id: forum.lastMessage.user.id, slug: forum.lastMessage.user.slug}) }}" class="text-decoration-none">
                                                            <strong>{{ forum.lastMessage.user.username }}</strong>
                                                        </a>
                                                    </small>
                                                {% else %}
                                                    <small class="text-muted">{{ 'forum.no_message'|trans }}</small>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="4" class="text-center text-muted">{{ 'forum.no_forum'|trans }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                {% else %}
                    <div class="alert alert-info">{{ 'forum.no_category'|trans }}</div>
                {% endfor %}
            </div>

            <div class="tab-pane fade" id="recent" role="tabpanel" aria-labelledby="recent-tab">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-clock-history"></i> {{ 'forum.recent.title'|trans({'%days%': recentActivityDays}) }}
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        {% if recentTopics|length > 0 %}
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>{{ 'forum.table.topic'|trans }}</th>
                                        <th class="d-none d-sm-table-cell" style="width: 150px;">{{ 'forum.table.forum'|trans }}</th>
                                        <th class="text-center d-none d-sm-table-cell" style="width: 80px;">{{ 'forum.table.messages'|trans }}</th>
                                        <th class="d-none d-md-table-cell" style="width: 220px;">{{ 'forum.table.last_message'|trans }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for topic in recentTopics %}
                                        <tr>
                                            <td>
                                                <i class="bi bi-chat-dots me-2"></i>
                                                <a href="{{ path('topic_show', {id: topic.id, slug: topic.slug, forumId: topic.forum.id, forumSlug: topic.forum.slug}) }}" class="text-decoration-none">
                                                    <strong>{{ topic.name }}</strong>
                                                </a>
                                                {% if topic.type %}
                                                    <span class="badge topic-type--{{ topic.type.name|lower }} ms-1">{{ topic.type.name }}</span>
                                                {% endif %}
                                                <br>
                                                <small class="text-muted">
                                                    {{ 'forum.show.started_by'|trans }}
                                                    <a href="{{ path('vgr_player_profile_overview', {id: topic.user.id, slug: topic.user.slug}) }}" class="text-decoration-none">
                                                        {{ topic.user.username }}
                                                    </a>
                                                </small>
                                            </td>
                                            <td class="d-none d-sm-table-cell">
                                                <a href="{{ path('forum_show', {id: topic.forum.id, slug: topic.forum.slug}) }}" class="text-decoration-none">
                                                    {% if app.request.locale == 'fr' and topic.forum.libForumFr %}
                                                        {{ topic.forum.libForumFr }}
                                                    {% else %}
                                                        {{ topic.forum.libForum }}
                                                    {% endif %}
                                                </a>
                                            </td>
                                            <td class="text-center d-none d-sm-table-cell">{{ topic.nbMessage }}</td>
                                            <td class="d-none d-md-table-cell">
                                                {% if topic.lastMessage %}
                                                    <small class="text-muted">
                                                        {{ topic.lastMessage.createdAt|date('d/m/Y H:i') }}<br>
                                                        {{ 'forum.by'|trans }}
                                                        <a href="{{ path('vgr_player_profile_overview', {id: topic.lastMessage.user.id, slug: topic.lastMessage.user.slug}) }}" class="text-decoration-none">
                                                            <strong>{{ topic.lastMessage.user.username }}</strong>
                                                        </a>
                                                    </small>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        {% else %}
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-clock" style="font-size: 3rem;"></i>
                                <p class="mt-3 mb-0">{{ 'forum.recent.no_topics'|trans({'%days%': recentActivityDays}) }}</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
