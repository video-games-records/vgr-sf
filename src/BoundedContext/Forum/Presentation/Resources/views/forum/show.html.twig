{% extends '@SharedKernel/base.html.twig' %}

{% trans_default_domain 'Forum' %}

{% block title %}
    {% if app.request.locale == 'fr' and forum.libForumFr %}
        {{ forum.libForumFr }}
    {% else %}
        {{ forum.libForum }}
    {% endif %}
    - {{ 'forum.title'|trans }} - {{ parent() }}
{% endblock %}

{% block body %}
<div class="container">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('home') }}">
                    <i class="bi bi-house"></i> {{ 'breadcrumb.home'|trans }}
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="{{ path('forum_index') }}">{{ 'forum.title'|trans }}</a>
            </li>
            {% if forum.category %}
            <li class="breadcrumb-item">
                {{ forum.category.name }}
            </li>
            {% endif %}
            <li class="breadcrumb-item active" aria-current="page">
                {% if app.request.locale == 'fr' and forum.libForumFr %}
                    {{ forum.libForumFr }}
                {% else %}
                    {{ forum.libForum }}
                {% endif %}
            </li>
        </ol>
    </nav>

    <div class="mb-4">
        <h1 class="h3">
            <i class="bi bi-chat-left-text"></i>
            {% if app.request.locale == 'fr' and forum.libForumFr %}
                {{ forum.libForumFr }}
            {% else %}
                {{ forum.libForum }}
            {% endif %}
        </h1>
        <p class="text-muted">{{ 'forum.show.description'|trans({'%count%': totalTopics}) }}</p>
    </div>

    {% if is_granted('ROLE_USER') %}
    <div class="mb-3 d-flex gap-2">
        <a href="{{ path('forum_create_topic', {id: forum.id, slug: forum.slug}) }}" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> {{ 'forum.show.new_topic'|trans }}
        </a>
        <form method="post" action="{{ path('forum_mark_as_read', {id: forum.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('mark_forum_read_' ~ forum.id) }}">
            <button type="submit" class="btn btn-outline-secondary">
                <i class="bi bi-check2-all"></i> {{ 'forum.show.mark_all_read'|trans }}
            </button>
        </form>
    </div>
    {% endif %}

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>{{ 'forum.show.topics_list'|trans }}</span>
        </div>
        <div class="card-body p-0">
            {% if topics|length > 0 %}
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>{{ 'forum.show.table.topic'|trans }}</th>
                            <th class="d-none d-sm-table-cell" style="width: 100px;">{{ 'forum.show.table.type'|trans }}</th>
                            <th class="text-center d-none d-sm-table-cell" style="width: 80px;">{{ 'forum.show.table.messages'|trans }}</th>
                            <th class="d-none d-md-table-cell" style="width: 200px;">{{ 'forum.show.table.last_message'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for topic in topics %}
                            {% set hasUnread = is_granted('ROLE_USER') and topic.hasNewContent %}
                            <tr{% if hasUnread %} class="table-info"{% endif %}>
                                <td>
                                    {% if hasUnread %}
                                        <i class="bi bi-chat-dots-fill text-primary me-2" title="{{ 'forum.unread'|trans }}"></i>
                                    {% else %}
                                        <i class="bi bi-chat-dots me-2"></i>
                                    {% endif %}
                                    <a href="{{ path('topic_show', {id: topic.id, slug: topic.slug, forumId: forum.id, forumSlug: forum.slug}) }}" class="text-decoration-none">
                                        {% if hasUnread %}<strong class="text-primary">{% endif %}
                                        {{ topic.name }}
                                        {% if hasUnread %}</strong>{% endif %}
                                    </a>
                                    {% if hasUnread %}
                                        <span class="badge bg-primary ms-1">{{ 'forum.new'|trans }}</span>
                                    {% endif %}
                                    {% set topicPages = ((topic.nbMessage - 1) / 20)|round(0, 'floor') + 1 %}
                                    {% if topicPages > 1 %}
                                        <a href="{{ path('topic_show', {id: topic.id, slug: topic.slug, forumId: forum.id, forumSlug: forum.slug, page: topicPages}) }}" class="badge bg-secondary text-decoration-none ms-1" title="{{ 'forum.show.go_to_last_page'|trans }}">
                                            {{ topicPages }}
                                        </a>
                                    {% endif %}
                                    <br>
                                    <small class="text-muted">
                                        {{ 'forum.show.started_by'|trans }}
                                        <a href="{{ path('vgr_player_profile_overview', {id: topic.user.id, slug: topic.user.slug}) }}" class="text-decoration-none">
                                            {{ topic.user.username }}
                                        </a>
                                    </small>
                                </td>
                                <td class="d-none d-sm-table-cell">
                                    {% if topic.type %}
                                        <span class="badge topic-type--{{ topic.type.name|lower }}">{{ topic.type.name }}</span>
                                    {% endif %}
                                </td>
                                <td class="text-center d-none d-sm-table-cell">{{ topic.nbMessage }}</td>
                                <td class="d-none d-md-table-cell">
                                    {% if topic.lastMessage %}
                                        <small class="text-muted">
                                            {{ topic.lastMessage.createdAt|date('d/m/Y H:i') }}<br>
                                            {{ 'forum.by'|trans }}
                                            <a href="{{ path('vgr_player_profile_overview', {id: topic.lastMessage.user.id, slug: topic.lastMessage.user.slug}) }}" class="text-decoration-none">
                                                <strong>{{ topic.lastMessage.user.username }}</strong>
                                            </a>
                                        </small>
                                    {% else %}
                                        <small class="text-muted">{{ 'forum.no_message'|trans }}</small>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-chat-left" style="font-size: 3rem;"></i>
                    <p class="mt-3 mb-0">{{ 'forum.show.no_topic'|trans }}</p>
                </div>
            {% endif %}
        </div>
    </div>

    {% if topics|length > 0 %}
        {% include '@Forum/forum/_pagination.html.twig' with {
            route: 'forum_show',
            routeParams: {id: forum.id, slug: forum.slug},
            currentPage: currentPage,
            totalPages: totalPages,
            totalItems: totalTopics,
            perPage: 20
        } %}
    {% endif %}
</div>
{% endblock %}
