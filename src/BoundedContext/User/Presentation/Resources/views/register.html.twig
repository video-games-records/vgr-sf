{% extends '../../../../../SharedKernel/Presentation/Resources/views/base.html.twig' %}
{% trans_default_domain 'User' %}

{% block title %}
    {{ 'registration.title'|trans }} - Video Games Records
{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="card-title text-center mb-2">{{ 'registration.title'|trans }}</h1>
                    <p class="text-center text-muted mb-4">{{ 'registration.subtitle'|trans }}</p>

                    {{ form_start(registrationForm, {'attr': {'data-turbo': 'false'}}) }}

                        {# Display global form errors #}
                        {{ form_errors(registrationForm) }}

                        <div class="mb-3">
                            {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.email) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(registrationForm.username, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.username, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.username) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(registrationForm.plainPassword.first, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.plainPassword.first) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(registrationForm.plainPassword.second, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.plainPassword.second) }}
                        </div>

                        <div class="d-grid">
                            {{ form_widget(registrationForm.submit, {'attr': {'class': 'btn btn-primary btn-lg'}}) }}
                        </div>

                    {{ form_end(registrationForm) }}

                    <div class="text-center mt-3">
                        <p class="mb-0">
                            {{ 'registration.link.have_account'|trans }}
                            <a href="{{ path('app_login') }}" class="text-decoration-none fw-bold">{{ 'registration.link.login'|trans }}</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
