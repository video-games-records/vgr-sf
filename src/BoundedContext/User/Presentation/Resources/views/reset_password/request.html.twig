{% extends 'base.html.twig' %}
{% trans_default_domain 'User' %}

{% block title %}
    {{ 'reset_password.request.title'|trans }} - Video Games Records
{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="card-title text-center mb-2">{{ 'reset_password.request.title'|trans }}</h1>
                    <p class="text-center text-muted mb-4">{{ 'reset_password.request.subtitle'|trans }}</p>

                    {{ form_start(form, {'attr': {'data-turbo': 'false'}}) }}

                        {# Display global form errors #}
                        {{ form_errors(form) }}

                        <div class="mb-3">
                            {{ form_label(form.email, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.email) }}
                            <div class="form-text">{{ 'reset_password.request.help'|trans }}</div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                {{ 'reset_password.request.submit'|trans }}
                            </button>
                        </div>

                    {{ form_end(form) }}

                    <div class="text-center mt-3">
                        <p class="mb-0">
                            <a href="{{ path('app_login') }}" class="text-decoration-none fw-bold">
                                {{ 'reset_password.request.back_to_login'|trans }}
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
