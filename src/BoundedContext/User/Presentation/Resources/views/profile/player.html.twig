{% extends 'base.html.twig' %}
{% trans_default_domain 'User' %}

{% block title %}{{ 'profile.navigation.player'|trans }} - {{ 'profile.title.main'|trans }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="profile-settings">
    <div class="mb-4">
        <h1>{{ 'profile.title.main'|trans }}</h1>
        <p class="text-muted">{{ 'profile.title.subtitle'|trans }}</p>
    </div>

    {# Flash Messages #}
    {% for label, messages in app.flashes() %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {% if label == 'success' %}
                    <i class="bi bi-check-circle"></i>
                {% elseif label == 'error' %}
                    <i class="bi bi-exclamation-circle"></i>
                {% endif %}
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ 'common.close'|trans }}"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card shadow-sm">
        <div class="card-body">
            {% include '@User/profile/_navigation.html.twig' %}

            {# Player Profile Content #}
            <div class="profile-section">
                <h3 class="mb-4">{{ 'profile.player.title'|trans }}</h3>
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> {{ 'profile.player.description'|trans }}
                </div>
                {# TODO: Add player statistics and achievements display #}
            </div>
        </div>
    </div>
</div>
{% endblock %}
