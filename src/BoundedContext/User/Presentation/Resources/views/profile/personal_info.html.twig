{% extends '@SharedKernel/base.html.twig' %}
{% trans_default_domain 'User' %}

{% block title %}{{ 'profile.navigation.personal_info'|trans }} - {{ 'profile.title.main'|trans }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="profile-settings">
    <div class="mb-4">
        <h1>{{ 'profile.title.main'|trans }}</h1>
        <p class="text-muted">{{ 'profile.title.subtitle'|trans }}</p>
    </div>

    {# Flash Messages #}
    {% for label, messages in app.flashes() %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {% if label == 'success' %}
                    <i class="bi bi-check-circle"></i>
                {% elseif label == 'error' %}
                    <i class="bi bi-exclamation-circle"></i>
                {% endif %}
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ 'common.close'|trans }}"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card shadow-sm">
        <div class="card-body">
            {% include '@User/profile/_navigation.html.twig' %}

            {# Personal Info Content #}
            <div class="profile-section">
                <h3 class="mb-4">{{ 'profile.personal_info.title'|trans }}</h3>
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> {{ 'profile.personal_info.description'|trans }}
                </div>

                {{ form_start(form) }}
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.username) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.email) }}
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.language) }}
                        </div>
                    </div>
                    <div class="mt-3">
                        {{ form_widget(form.submit) }}
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
