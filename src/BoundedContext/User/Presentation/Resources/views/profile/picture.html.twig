{% extends '@SharedKernel/base.html.twig' %}
{% trans_default_domain 'User' %}

{% block title %}{{ 'profile.navigation.picture'|trans }} - {{ 'profile.title.main'|trans }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="container py-4">
<div class="profile-settings">
    <div class="mb-4">
        <h1>{{ 'profile.title.main'|trans }}</h1>
        <p class="text-muted">{{ 'profile.title.subtitle'|trans }}</p>
    </div>

    {# Flash Messages #}
    {% for label, messages in app.flashes() %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {% if label == 'success' %}
                    <i class="bi bi-check-circle"></i>
                {% elseif label == 'error' %}
                    <i class="bi bi-exclamation-circle"></i>
                {% endif %}
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ 'common.close'|trans }}"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card shadow-sm">
        <div class="card-body">
            {% include '@User/profile/_navigation.html.twig' %}

            {# Profile Picture Content #}
            <div class="profile-section">
                <h3 class="mb-4">{{ 'profile.picture.title'|trans }}</h3>

                {# Current Avatar #}
                <div class="text-center mb-4">
                    <img src="{{ path('pn_user_avatar_show', {id: app.user.id}) }}"
                         alt="{{ 'profile.picture.current_avatar'|trans }}"
                         class="rounded-circle border"
                         width="150"
                         height="150"
                         id="avatar-preview">
                </div>

                {# Upload Form #}
                {{ form_start(form, {'attr': {'class': 'mt-3'}}) }}
                    <div class="row justify-content-center">
                        <div class="col-md-6">
                            {{ form_row(form.avatar) }}
                            <div class="form-text">
                                {{ 'profile.picture.form.help'|trans }}
                            </div>
                            <div class="mt-3">
                                {{ form_widget(form.submit) }}
                            </div>
                        </div>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
</div>
{% endblock %}
