{% extends 'base.html.twig' %}
{% trans_default_domain 'User' %}

{% block title %}
    {{ 'login.title'|trans }} - Video Games Records
{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="card-title text-center mb-4">
                        {{ 'login.title'|trans }}
                    </h1>

                    {% if error %}
                        <div class="alert alert-danger" role="alert">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <form method="post" action="{{ path(admin|default(false) ? 'sonata_user_admin_security_check' : 'app_login') }}" data-turbo="false">
                        <div class="mb-3">
                            <label for="username" class="form-label">
                                {{ 'login.form.username_or_email.label'|trans }}
                            </label>
                            <input
                                type="text"
                                class="form-control"
                                id="username"
                                name="_username"
                                value="{{ last_username }}"
                                required
                                autofocus
                            >
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">
                                {{ 'login.form.password.label'|trans }}
                            </label>
                            <input
                                type="password"
                                class="form-control"
                                id="password"
                                name="_password"
                                required
                            >
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                {{ 'login.form.submit'|trans }}
                            </button>
                        </div>
                    </form>

                    <div class="text-center mt-3">
                        <p class="mb-0">
                            {{ 'login.link.no_account'|trans }}
                            <a href="{{ path('app_register') }}" class="text-decoration-none fw-bold">
                                {{ 'login.link.register'|trans }}
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
