{% extends '@SharedKernel/base.html.twig' %}
{% trans_default_domain 'Message' %}

{% block title %}{{ 'inbox.title'|trans }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('home') }}">
                    <i class="bi bi-house"></i> {{ 'breadcrumb.home'|trans }}
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                {{ 'breadcrumb.messages'|trans }}
            </li>
        </ol>
    </nav>

    <div class="mb-4">
        <h1 class="h3">
            <i class="bi bi-envelope"></i> {{ 'inbox.header'|trans }}
        </h1>
        <p class="text-muted">{{ 'inbox.description'|trans({'%count%': totalMessages}) }}</p>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            {% include '@Message/message/_navigation.html.twig' %}

            {% include '@Message/message/_filters.html.twig' with {
                type: 'inbox',
                senders: senders,
                filters: filters
            } %}

            {% if messages|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 40px;"></th>
                                <th>{{ 'inbox.column.sender'|trans }}</th>
                                <th>{{ 'inbox.column.subject'|trans }}</th>
                                <th class="text-center d-none d-md-table-cell" style="width: 150px;">{{ 'inbox.column.date'|trans }}</th>
                                <th class="text-center" style="width: 100px;">{{ 'inbox.column.actions'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for message in messages %}
                                <tr class="{{ not message.isOpened ? 'table-primary fw-bold' : '' }}">
                                    <td class="text-center">
                                        {% if not message.isOpened %}
                                            <i class="bi bi-envelope-fill text-primary" title="{{ 'inbox.unread'|trans }}"></i>
                                        {% else %}
                                            <i class="bi bi-envelope-open text-muted" title="{{ 'inbox.read'|trans }}"></i>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="/users/{{ message.sender.id }}/avatar"
                                                 alt="{{ message.sender.username }}"
                                                 class="rounded-circle me-2"
                                                 width="32" height="32">
                                            <span>{{ message.sender.username }}</span>
                                        </div>
                                    </td>
                                    <td>
                                        <a href="{{ path('message_view', {id: message.id}) }}" class="text-decoration-none">
                                            {{ message.object }}
                                        </a>
                                        {% if message.type != 'DEFAULT' %}
                                            <span class="badge bg-secondary ms-1">{{ message.type }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center d-none d-md-table-cell text-body-secondary">
                                        <small>{{ message.createdAt|date('d/m/Y H:i') }}</small>
                                    </td>
                                    <td class="text-center">
                                        <a href="{{ path('message_view', {id: message.id}) }}"
                                           class="btn btn-sm btn-outline-primary"
                                           title="{{ 'inbox.action.view'|trans }}">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <form action="{{ path('message_delete', {id: message.id}) }}"
                                              method="POST"
                                              class="d-inline"
                                              onsubmit="return confirm('{{ 'inbox.confirm_delete'|trans }}');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete-message-' ~ message.id) }}">
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger"
                                                    title="{{ 'inbox.action.delete'|trans }}">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {% include '@Message/message/_pagination.html.twig' with {
                    route: 'message_inbox',
                    filters: filters,
                    currentPage: currentPage,
                    totalPages: totalPages,
                    totalMessages: totalMessages
                } %}
            {% else %}
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                    <p class="mt-3 mb-0">{{ 'inbox.empty'|trans }}</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
