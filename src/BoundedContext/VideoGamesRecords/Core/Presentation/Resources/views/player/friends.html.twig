{% extends '@SharedKernel/base.html.twig' %}
{% trans_default_domain 'VgrCore' %}

{% block title %}{{ 'friend.title'|trans }}{% endblock %}

{% block body %}
<div class="container py-4">
    {# Breadcrumb #}
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('home') }}">
                    <i class="bi bi-house"></i> {{ 'breadcrumb.home'|trans }}
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                {{ 'friend.header'|trans }}
            </li>
        </ol>
    </nav>

    {# Header #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            <i class="bi bi-people"></i> {{ 'friend.header'|trans }}
        </h1>
        <span class="badge bg-primary fs-6">{{ 'friend.description'|trans({'%count%': friends|length}) }}</span>
    </div>

    {# Add Friend Form #}
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form method="post" action="{{ path('vgr_friends_add') }}" class="d-flex flex-wrap gap-2 align-items-end" data-turbo="false">
                <input type="hidden" name="_token" value="{{ csrf_token('add-friend') }}">
                <div class="flex-grow-1" style="min-width: 200px; max-width: 400px;">
                    <label class="form-label" for="friend_player">{{ 'friend.add.label'|trans }}</label>
                    <input type="text" id="friend_player" name="player"
                           data-controller="tomselect"
                           data-tomselect-url-value="/api/players/autocomplete"
                           data-tomselect-placeholder-value="{{ 'friend.add.placeholder'|trans }}"
                           data-tomselect-max-items-value="1"
                           placeholder="{{ 'friend.add.placeholder'|trans }}"
                           class="form-control">
                </div>
                <div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-person-plus"></i> {{ 'friend.add.submit'|trans }}
                    </button>
                </div>
            </form>
        </div>
    </div>

    {# Friends Grid #}
    {% if friends|length > 0 %}
        <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-6 g-3">
            {% for friend in friends %}
                <div class="col">
                    <div class="card shadow-sm h-100 text-center">
                        <div class="card-body p-3">
                            <a href="{{ path('vgr_player_profile_overview', {id: friend.id, slug: friend.slug}) }}" class="text-decoration-none">
                                <img src="/users/{{ friend.getUserId() }}/avatar"
                                     alt="{{ friend.pseudo }}"
                                     class="rounded-circle mb-2"
                                     width="64" height="64">
                                <h6 class="card-title mb-0 text-truncate">{{ friend.pseudo }}</h6>
                            </a>
                        </div>
                        <div class="card-footer bg-transparent border-0 p-2">
                            <form method="post" action="{{ path('vgr_friends_remove', {id: friend.id}) }}" onsubmit="return confirm('{{ 'friend.remove.confirm'|trans }}');">
                                <input type="hidden" name="_token" value="{{ csrf_token('remove-friend-' ~ friend.id) }}">
                                <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                    <i class="bi bi-person-dash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-people" style="font-size: 4rem; color: #6c757d;"></i>
                <h4 class="mt-3">{{ 'friend.empty'|trans }}</h4>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
