{% extends '@VideoGamesRecordsCore/player/profile/_base.html.twig' %}
{% trans_default_domain 'VgrCore' %}

{% block profile_content %}
{# Master Badges Section #}
{% if masterBadgesData|length > 0 %}
<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title mb-3">
            <i class="bi bi-patch-check text-warning"></i>
            {{ 'player.profile.badges.master_title'|trans }}
            <span class="badge bg-secondary">{{ masterBadgesData|length }}</span>
        </h5>

        <div class="d-flex flex-wrap gap-1">
            {% for badge in masterBadgesData %}
                {% set game = games[badge.badgeId] ?? null %}
                {% set gameName = game ? game.getName(app.request.locale) : 'Badge' %}
                <span class="badge-item"
                      data-bs-toggle="tooltip"
                      data-bs-placement="top"
                      title="Master - {{ gameName }} | {{ 'player.profile.badges.value'|trans }}: {{ badge.badgeValue }} | {{ 'player.profile.badges.obtained'|trans }}: {{ badge.createdAt|date('d/m/Y') }}">
                    <img src="/badge/{{ badge.badgeId }}/picture"
                         alt="{{ gameName }}"
                         width="40"
                         height="40"
                         class="border rounded">
                </span>
            {% endfor %}
        </div>
    </div>
</div>
{% endif %}

