{% extends '@SharedKernel/base.html.twig' %}
{% trans_default_domain 'VgrCore' %}

{% block title %}{{ country.getName(app.request.locale) }} - {{ 'country.show.title'|trans }}{% endblock %}

{% block meta_description %}{{ 'country.show.meta_description'|trans({'%country%': country.getName(app.request.locale)}) }}{% endblock %}

{% block body %}
<div class="container py-4">
    {# Breadcrumb Navigation #}
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('home') }}">
                    <i class="bi bi-house"></i> {{ 'breadcrumb.home'|trans }}
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                {{ country.getName(app.request.locale) }}
            </li>
        </ol>
    </nav>

    {# Country Header Card #}
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-auto">
                    <img src="{{ asset('build/icons/flags/' ~ country.codeIso2|lower ~ '.svg') }}"
                         alt="{{ country.getName(app.request.locale) }}"
                         width="64"
                         height="48"
                         class="border rounded"
                         onerror="this.style.display='none'">
                </div>
                <div class="col">
                    <h1 class="h3 mb-2">{{ country.getName(app.request.locale) }}</h1>
                    <span class="badge bg-secondary">{{ country.codeIso2 }}</span>
                </div>
            </div>
        </div>
    </div>

    {# Country Selector #}
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <label for="country-select" class="form-label fw-bold">
                <i class="bi bi-globe"></i> {{ 'country.show.select_country'|trans }}
            </label>
            <select id="country-select" class="form-select" onchange="Turbo.visit(this.value)">
                {% for c in countries %}
                    <option value="{{ path('vgr_country_show', {id: c.id, slug: c.slug}) }}"
                            {% if c.id == country.id %}selected{% endif %}>
                        {{ c.getName(app.request.locale) }}
                    </option>
                {% endfor %}
            </select>
        </div>
    </div>

    {# Ranking Points #}
    <div class="card shadow-sm">
        <div class="card-header">
            <h2 class="h5 mb-0">
                <i class="bi bi-trophy"></i> {{ 'country.show.ranking_points'|trans }}
            </h2>
        </div>
        {% if rankingPoints|length > 0 %}
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th class="text-center" style="width: 80px;">{{ 'leaderboard.columns.rank'|trans }}</th>
                            <th>{{ 'leaderboard.columns.player'|trans }}</th>
                            <th class="text-end">{{ 'leaderboard.columns.points'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for player in rankingPoints %}
                            <tr {% if app.user and player.getUserId() == app.user.id %}class="table-primary"{% endif %}>
                                <td class="text-center align-middle">
                                    <span class="badge rounded-pill {% if loop.index <= 3 %}bg-warning text-dark{% else %}bg-secondary{% endif %}">
                                        {{ player.rankCountry }}
                                    </span>
                                </td>
                                <td class="align-middle">
                                    {{ component('player_link', {
                                        player: player,
                                        showTeam: true,
                                        showCountry: false,
                                        showAvatar: false
                                    }) }}
                                </td>
                                <td class="text-end align-middle">
                                    {{ player.pointChart|number_format(0, '.', ',') }}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="card-body text-center text-muted py-5">
                <i class="bi bi-trophy" style="font-size: 3rem;"></i>
                <p class="mt-3 mb-0">{{ 'leaderboard.no_players'|trans }}</p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

