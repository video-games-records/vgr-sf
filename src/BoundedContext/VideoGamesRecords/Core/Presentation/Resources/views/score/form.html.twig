{% extends '@SharedKernel/base.html.twig' %}
{% trans_default_domain 'VgrCore' %}

{% block title %}
    {% if context == 'chart' %}
        {{ chart.name }} - {{ 'score.form.title'|trans }}
    {% elseif context == 'group' %}
        {{ group.name }} - {{ 'score.form.title'|trans }}
    {% else %}
        {{ game.name }} - {{ 'score.form.title'|trans }}
    {% endif %}
{% endblock %}

{% block body %}
<div class="container py-4" data-controller="score-form">
    {# Build breadcrumbs based on context #}
    {% set breadcrumbs = [] %}
    {% set breadcrumbs = breadcrumbs|merge([{
        'url': path('vgr_game_show', {id: game.id, slug: game.slug}),
        'label': game.name
    }]) %}
    {% if context == 'group' or context == 'chart' %}
        {% set breadcrumbs = breadcrumbs|merge([{
            'url': path('vgr_group_show', {id: game.id, slug: game.slug, groupId: group.id, groupSlug: group.slug}),
            'label': group.name
        }]) %}
    {% endif %}
    {% if context == 'chart' %}
        {% set breadcrumbs = breadcrumbs|merge([{'label': chart.name ~ ' - ' ~ 'score.form.title'|trans}]) %}
    {% else %}
        {% set breadcrumbs = breadcrumbs|merge([{'label': 'score.form.title'|trans}]) %}
    {% endif %}

    {# Include game header #}
    {% include '@VideoGamesRecordsCore/game/_header.html.twig' with {
        'game': game,
        'breadcrumbs': breadcrumbs
    } %}

    {# Main content with sidebar #}
    <div class="row">
        {# Main Content Column #}
        <div class="col-lg-9">
            {# Search bar (only for game context) #}
            {% if context == 'game' %}
                {% include '@VideoGamesRecordsCore/score/_search.html.twig' %}
            {% endif %}

            {# Flash messages #}
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            <form method="post" id="score-form">
                <div class="card shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>
                            <i class="bi bi-controller"></i> {{ 'score.form.charts'|trans }}
                        </span>
                        <span class="badge bg-primary" data-score-form-target="counter">0 {{ 'score.form.modified'|trans }}</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>{{ 'score.form.chart'|trans }}</th>
                                    <th class="d-none d-md-table-cell">{{ 'score.form.current_score'|trans }}</th>
                                    <th>{{ 'score.form.new_score'|trans }}</th>
                                    <th class="d-none d-md-table-cell">{{ 'score.form.platform'|trans }}</th>
                                    <th class="text-center">{{ 'score.form.status'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for chartData in chartsData %}
                                    {% include '@VideoGamesRecordsCore/score/_chart_row.html.twig' with {
                                        'chart': chartData.chart,
                                        'playerChart': chartData.playerChart,
                                        'existingValues': chartData.existingValues,
                                        'originalData': chartData.originalData,
                                        'platforms': platforms
                                    } %}
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-5">
                                            <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                                            <p class="mt-3 mb-0">{{ 'score.form.no_charts'|trans }}</p>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>

                {% if chartsData|length > 0 %}
                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-circle"></i> {{ 'score.form.submit'|trans }}
                        </button>
                        <span class="text-muted" data-score-form-target="summary"></span>
                    </div>
                {% endif %}
            </form>

            {# Pagination #}
            {% set totalItems = paginator.totalItems %}
            {% set totalPages = paginator.lastPage|round(0, 'ceil') %}
            {% set currentPage = paginator.currentPage|round(0, 'ceil') %}
            {% set itemsPerPage = paginator.itemsPerPage|round(0, 'ceil') %}

            {% if totalPages > 1 %}
                <nav class="mt-4" aria-label="Page navigation">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <small class="text-muted">
                            {{ 'score.form.pagination_info'|trans({'%current%': currentPage, '%total%': totalPages, '%items%': totalItems|round(0, 'ceil')}) }}
                        </small>
                    </div>
                    <ul class="pagination justify-content-center">
                        {# Previous button #}
                        <li class="page-item {{ currentPage == 1 ? 'disabled' }}">
                            {% set prevParams = app.request.query.all|merge({'page': currentPage - 1}) %}
                            <a class="page-link" href="{{ app.request.pathInfo }}?{{ prevParams|url_encode }}" aria-label="Previous">
                                <span aria-hidden="true">&laquo;</span>
                            </a>
                        </li>

                        {# Page numbers #}
                        {% for p in 1..totalPages %}
                            {% if p == 1 or p == totalPages or (p >= currentPage - 2 and p <= currentPage + 2) %}
                                {% set pageParams = app.request.query.all|merge({'page': p}) %}
                                <li class="page-item {{ p == currentPage ? 'active' }}">
                                    <a class="page-link" href="{{ app.request.pathInfo }}?{{ pageParams|url_encode }}">{{ p }}</a>
                                </li>
                            {% elseif p == currentPage - 3 or p == currentPage + 3 %}
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            {% endif %}
                        {% endfor %}

                        {# Next button #}
                        <li class="page-item {{ currentPage == totalPages ? 'disabled' }}">
                            {% set nextParams = app.request.query.all|merge({'page': currentPage + 1}) %}
                            <a class="page-link" href="{{ app.request.pathInfo }}?{{ nextParams|url_encode }}" aria-label="Next">
                                <span aria-hidden="true">&raquo;</span>
                            </a>
                        </li>
                    </ul>
                </nav>
            {% endif %}
        </div>

        {# Sidebar Column #}
        <div class="col-lg-3 mt-4 mt-lg-0">
            {% include '@VideoGamesRecordsCore/game/_sidebar.html.twig' with {
                'game': game,
                'group': group|default(null),
                'chart': chart|default(null)
            } %}
        </div>
    </div>
</div>
{% endblock %}
