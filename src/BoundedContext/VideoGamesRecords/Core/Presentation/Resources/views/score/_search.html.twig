{# Search bar for score form #}
{% trans_default_domain 'VgrCore' %}

<div class="card mb-4 shadow-sm">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-8 col-lg-9">
                <label for="search" class="form-label">
                    <i class="bi bi-search"></i> {{ 'score.form.search_label'|trans }}
                </label>
                <input type="text"
                       id="search"
                       name="search"
                       class="form-control"
                       placeholder="{{ 'score.form.search_placeholder'|trans }}"
                       value="{{ searchTerm }}">
            </div>
            <div class="col-md-4 col-lg-3">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> {{ 'score.form.search_button'|trans }}
                </button>
            </div>
        </form>
        {% if searchTerm %}
            <div class="mt-2">
                <a href="{{ app.request.pathInfo }}" class="text-decoration-none small">
                    <i class="bi bi-x-circle"></i> {{ 'score.form.clear_search'|trans }}
                </a>
            </div>
        {% endif %}
    </div>
</div>
