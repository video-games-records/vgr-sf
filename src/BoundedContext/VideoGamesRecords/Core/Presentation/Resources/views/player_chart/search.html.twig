{% extends '@SharedKernel/base.html.twig' %}
{% trans_default_domain 'VgrCore' %}

{% block title %}{{ 'player_chart.search.title'|trans }}{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="bi bi-search"></i> {{ 'player_chart.search.title'|trans }}
            </h5>
        </div>
        <div class="card-body">
            {{ form_start(form, {'attr': {'data-turbo': 'false'}}) }}
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        {{ form_label(form.games) }}
                        {{ form_widget(form.games, {
                            'value': gamesData|map(g => g.id)|join(','),
                            'attr': {
                                'data-tomselect-items-value': gamesData|json_encode
                            }
                        }) }}
                        {{ form_errors(form.games) }}
                    </div>
                    <div class="col-md-4">
                        {{ form_label(form.players) }}
                        {{ form_widget(form.players, {
                            'value': playersData|map(p => p.id)|join(','),
                            'attr': {
                                'data-tomselect-items-value': playersData|json_encode
                            }
                        }) }}
                        {{ form_errors(form.players) }}
                    </div>
                    <div class="col-md-4">
                        {{ form_label(form.platforms) }}
                        {{ form_widget(form.platforms, {
                            'value': platformsData|map(p => p.id)|join(','),
                            'attr': {
                                'data-tomselect-items-value': platformsData|json_encode
                            }
                        }) }}
                        {{ form_errors(form.platforms) }}
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-md-2">
                        {{ form_row(form.statuses) }}
                    </div>
                    <div class="col-md-2">
                        {{ form_label(form.rank_operator) }}
                        <div class="input-group">
                            {{ form_widget(form.rank_operator) }}
                            {{ form_widget(form.rank_value, {'attr': {'class': 'form-control'}}) }}
                            <span class="input-group-text">#</span>
                        </div>
                    </div>
                    <div class="col-md-2">
                        {{ form_label(form.points_operator) }}
                        <div class="input-group">
                            {{ form_widget(form.points_operator) }}
                            {{ form_widget(form.points_value, {'attr': {'class': 'form-control'}}) }}
                            <span class="input-group-text"><i class="bi bi-star"></i></span>
                        </div>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        {{ form_row(form.platinum_only) }}
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        {{ form_widget(form.submit) }}
                    </div>
                </div>
            {{ form_end(form) }}
        </div>
    </div>

    {% if playerCharts is defined and playerCharts|length > 0 %}
        <div class="card shadow-sm mt-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-trophy"></i> {{ 'player_chart.search.results'|trans }}
                    {% if pagination %}
                        ({{ pagination.totalItems }})
                    {% endif %}
                </h5>
                {% if pagination and pagination.totalPages > 1 %}
                    <small class="text-muted">
                        {{ 'player_chart.search.page'|trans }} {{ pagination.currentPage }} / {{ pagination.totalPages }}
                    </small>
                {% endif %}
            </div>
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>{{ 'player_chart.search.player'|trans }}</th>
                            <th>{{ 'player_chart.search.chart'|trans }}</th>
                            <th class="text-center">{{ 'player_chart.search.rank'|trans }}</th>
                            <th class="text-center">{{ 'player_chart.search.points'|trans }}</th>
                            <th>{{ 'player_chart.search.platform'|trans }}</th>
                            <th class="text-end">{{ 'player_chart.search.value'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for playerChart in playerCharts %}
                            <tr>
                                <td>
                                    <a href="{{ path('vgr_player_profile_overview', {id: playerChart.player.id, slug: playerChart.player.slug}) }}">
                                        {{ playerChart.player.pseudo }}
                                    </a>
                                </td>
                                <td>
                                    <a href="{{ path('vgr_chart_show', {id: playerChart.chart.group.game.id, slug: playerChart.chart.group.game.slug, groupId: playerChart.chart.group.id, groupSlug: playerChart.chart.group.slug, chartId: playerChart.chart.id, chartSlug: playerChart.chart.slug}) }}">
                                        {{ playerChart.chart.group.game.name }} - {{ playerChart.chart.group.name }} - {{ playerChart.chart.name }}
                                    </a>
                                </td>
                                <td class="text-center">
                                    {% if playerChart.rank == 1 %}
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-trophy-fill"></i> 1
                                        </span>
                                    {% elseif playerChart.rank == 2 %}
                                        <span class="badge bg-secondary">2</span>
                                    {% elseif playerChart.rank == 3 %}
                                        <span class="badge bg-danger">3</span>
                                    {% else %}
                                        {{ playerChart.rank }}
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    {{ playerChart.pointChart }}
                                </td>
                                <td>
                                    {% if playerChart.platform %}
                                        {{ component('platform_badge', {platform: playerChart.platform}) }}
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    {% for lib in playerChart.libs %}
                                        {{ lib.formatValue }}{% if not loop.last %} / {% endif %}
                                    {% endfor %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {# Pagination #}
            {% if pagination and pagination.totalPages > 1 %}
                <div class="card-footer">
                    <nav aria-label="Search results pagination">
                        <ul class="pagination pagination-sm mb-0 justify-content-center">
                            {# Previous #}
                            <li class="page-item {% if pagination.currentPage == 1 %}disabled{% endif %}">
                                <a class="page-link" href="{{ path('vgr_score_search', {page: pagination.currentPage - 1}) }}">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>

                            {# Page numbers #}
                            {% set startPage = max(1, pagination.currentPage - 2) %}
                            {% set endPage = min(pagination.totalPages, pagination.currentPage + 2) %}

                            {% if startPage > 1 %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('vgr_score_search', {page: 1}) }}">1</a>
                                </li>
                                {% if startPage > 2 %}
                                    <li class="page-item disabled"><span class="page-link">...</span></li>
                                {% endif %}
                            {% endif %}

                            {% for p in startPage..endPage %}
                                <li class="page-item {% if p == pagination.currentPage %}active{% endif %}">
                                    <a class="page-link" href="{{ path('vgr_score_search', {page: p}) }}">{{ p }}</a>
                                </li>
                            {% endfor %}

                            {% if endPage < pagination.totalPages %}
                                {% if endPage < pagination.totalPages - 1 %}
                                    <li class="page-item disabled"><span class="page-link">...</span></li>
                                {% endif %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('vgr_score_search', {page: pagination.totalPages}) }}">{{ pagination.totalPages }}</a>
                                </li>
                            {% endif %}

                            {# Next #}
                            <li class="page-item {% if pagination.currentPage == pagination.totalPages %}disabled{% endif %}">
                                <a class="page-link" href="{{ path('vgr_score_search', {page: pagination.currentPage + 1}) }}">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            {% endif %}
        </div>
    {% elseif playerCharts is defined %}
        <div class="alert alert-info mt-4">
            <i class="bi bi-info-circle"></i> {{ 'player_chart.search.no_results'|trans }}
        </div>
    {% endif %}
</div>
{% endblock %}
