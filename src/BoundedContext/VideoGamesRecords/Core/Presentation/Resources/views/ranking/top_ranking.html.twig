{% extends '@SharedKernel/base.html.twig' %}
{% trans_default_domain 'VgrCore' %}

{% block title %}{{ 'top_ranking.page_title'|trans }}{% endblock %}

{% block meta_description %}{{ 'top_ranking.meta_description'|trans }}{% endblock %}

{% block body %}
<div class="container py-4">
    <h1 class="mb-4">{{ 'top_ranking.title'|trans }}</h1>

    {# Filter Form #}
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" action="{{ path('vgr_top_ranking') }}" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label for="type" class="form-label">{{ 'top_ranking.filter.type'|trans }}</label>
                    <select name="type" id="type" class="form-select">
                        <option value="week" {{ type == 'week' ? 'selected' }}>{{ 'top_ranking.filter.week'|trans }}</option>
                        <option value="month" {{ type == 'month' ? 'selected' }}>{{ 'top_ranking.filter.month'|trans }}</option>
                        <option value="year" {{ type == 'year' ? 'selected' }}>{{ 'top_ranking.filter.year'|trans }}</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="value" class="form-label">{{ 'top_ranking.filter.value'|trans }}</label>
                    <input type="text" name="value" id="value" class="form-control" value="{{ value }}"
                           placeholder="{{ type == 'week' ? 'YYYY-Www' : (type == 'month' ? 'YYYY-MM' : 'YYYY') }}">
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> {{ 'top_ranking.filter.submit'|trans }}
                    </button>
                </div>
            </form>
        </div>
    </div>

    {# Top Games Section #}
    <h2 class="mb-3"><i class="bi bi-trophy text-warning"></i> {{ 'top_ranking.top_games'|trans }}</h2>

    {% if gameRankings|length > 0 %}
        {# Top 3 Cards #}
        <div class="row g-3 mb-4">
            {% for ranking in gameRankings|slice(0, 3) %}
                <div class="col-md-4">
                    <div class="card shadow-sm text-center h-100">
                        <div class="card-body">
                            <div class="mb-2">
                                {% if ranking.rank == 1 %}
                                    <span class="badge rounded-pill bg-warning text-dark fs-6">#1</span>
                                {% elseif ranking.rank == 2 %}
                                    <span class="badge rounded-pill bg-secondary fs-6">#2</span>
                                {% elseif ranking.rank == 3 %}
                                    <span class="badge rounded-pill bg-danger fs-6">#3</span>
                                {% endif %}
                            </div>
                            <img src="{{ path('vgr_core_game_picture', {id: ranking.game.id}) }}"
                                 alt="{{ ranking.game.name }}"
                                 class="rounded mb-3"
                                 width="100" height="100">
                            <h5 class="card-title">
                                <a href="{{ path('vgr_game_show', {id: ranking.game.id, slug: ranking.game.slug}) }}"
                                   class="text-decoration-none">
                                    {{ ranking.game.name }}
                                </a>
                            </h5>
                            <p class="text-muted mb-0">{{ ranking.nbPost }} {{ 'top_ranking.posts'|trans }}</p>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        {# Full Table #}
        <div class="card shadow-sm mb-5">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th class="text-center" style="width: 80px;">{{ 'top_ranking.columns.rank'|trans }}</th>
                            <th>{{ 'top_ranking.columns.game'|trans }}</th>
                            <th class="text-end">{{ 'top_ranking.columns.posts'|trans }}</th>
                            <th class="text-end" style="width: 100px;">{{ 'top_ranking.columns.change'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for ranking in gameRankings %}
                            <tr>
                                <td class="text-center">
                                    {% if ranking.rank == 1 %}
                                        <span class="badge rounded-pill bg-warning text-dark">#{{ ranking.rank }}</span>
                                    {% elseif ranking.rank == 2 %}
                                        <span class="badge rounded-pill bg-secondary">#{{ ranking.rank }}</span>
                                    {% elseif ranking.rank == 3 %}
                                        <span class="badge rounded-pill bg-danger">#{{ ranking.rank }}</span>
                                    {% else %}
                                        <span class="badge rounded-pill bg-light text-dark border">#{{ ranking.rank }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <a href="{{ path('vgr_game_show', {id: ranking.game.id, slug: ranking.game.slug}) }}"
                                       class="text-decoration-none">
                                        {{ ranking.game.name }}
                                    </a>
                                </td>
                                <td class="text-end">{{ ranking.nbPost }}</td>
                                <td class="text-end">
                                    {% if ranking.hasImproved() %}
                                        <span class="text-success"><i class="bi bi-arrow-up"></i> {{ ranking.positionChange }}</span>
                                    {% elseif ranking.hasDeclined() %}
                                        <span class="text-danger"><i class="bi bi-arrow-down"></i> {{ ranking.positionChange|abs }}</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% else %}
        <div class="card shadow-sm mb-5">
            <div class="card-body text-center text-muted py-5">
                <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                <p class="mt-3 mb-0">{{ 'top_ranking.no_rankings'|trans }}</p>
            </div>
        </div>
    {% endif %}

    {# Top Players Section #}
    <h2 class="mb-3"><i class="bi bi-trophy text-warning"></i> {{ 'top_ranking.top_players'|trans }}</h2>

    {% if playerRankings|length > 0 %}
        {# Top 3 Cards #}
        <div class="row g-3 mb-4">
            {% for ranking in playerRankings|slice(0, 3) %}
                <div class="col-md-4">
                    <div class="card shadow-sm text-center h-100">
                        <div class="card-body">
                            <div class="mb-2">
                                {% if ranking.rank == 1 %}
                                    <span class="badge rounded-pill bg-warning text-dark fs-6">#1</span>
                                {% elseif ranking.rank == 2 %}
                                    <span class="badge rounded-pill bg-secondary fs-6">#2</span>
                                {% elseif ranking.rank == 3 %}
                                    <span class="badge rounded-pill bg-danger fs-6">#3</span>
                                {% endif %}
                            </div>
                            <img src="/users/{{ ranking.player.getUserId() }}/avatar"
                                 alt="{{ ranking.player.pseudo }}"
                                 class="rounded-circle mb-3"
                                 width="80" height="80">
                            <h5 class="card-title">
                                <a href="{{ path('vgr_player_profile_overview', {id: ranking.player.id, slug: ranking.player.slug}) }}"
                                   class="text-decoration-none">
                                    {{ ranking.player.pseudo }}
                                </a>
                            </h5>
                            <p class="text-muted mb-0">{{ ranking.nbPost }} {{ 'top_ranking.posts'|trans }}</p>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        {# Full Table #}
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th class="text-center" style="width: 80px;">{{ 'top_ranking.columns.rank'|trans }}</th>
                            <th>{{ 'top_ranking.columns.player'|trans }}</th>
                            <th class="text-end">{{ 'top_ranking.columns.posts'|trans }}</th>
                            <th class="text-end" style="width: 100px;">{{ 'top_ranking.columns.change'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for ranking in playerRankings %}
                            <tr>
                                <td class="text-center">
                                    {% if ranking.rank == 1 %}
                                        <span class="badge rounded-pill bg-warning text-dark">#{{ ranking.rank }}</span>
                                    {% elseif ranking.rank == 2 %}
                                        <span class="badge rounded-pill bg-secondary">#{{ ranking.rank }}</span>
                                    {% elseif ranking.rank == 3 %}
                                        <span class="badge rounded-pill bg-danger">#{{ ranking.rank }}</span>
                                    {% else %}
                                        <span class="badge rounded-pill bg-light text-dark border">#{{ ranking.rank }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {{ component('player_link', {
                                        player: ranking.player,
                                        bold: false,
                                        showTeam: false,
                                        showCountry: true,
                                        showAvatar: true
                                    }) }}
                                </td>
                                <td class="text-end">{{ ranking.nbPost }}</td>
                                <td class="text-end">
                                    {% if ranking.hasImproved() %}
                                        <span class="text-success"><i class="bi bi-arrow-up"></i> {{ ranking.positionChange }}</span>
                                    {% elseif ranking.hasDeclined() %}
                                        <span class="text-danger"><i class="bi bi-arrow-down"></i> {{ ranking.positionChange|abs }}</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% else %}
        <div class="card shadow-sm">
            <div class="card-body text-center text-muted py-5">
                <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                <p class="mt-3 mb-0">{{ 'top_ranking.no_rankings'|trans }}</p>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
