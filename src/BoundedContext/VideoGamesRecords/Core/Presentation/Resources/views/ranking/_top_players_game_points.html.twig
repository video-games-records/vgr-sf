<div class="card border shadow-sm h-100">
    <div class="card-header border-bottom">
        <h5 class="mb-0"><i class="bi bi-graph-up-arrow"></i> Game Points</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 50px;">#</th>
                        <th>Player</th>
                        <th class="text-end">Points</th>
                    </tr>
                </thead>
                <tbody>
                    {% for player in players %}
                        <tr>
                            <td class="text-center">
                                <span class="badge rounded-pill {% if loop.index == 1 %}bg-warning text-dark{% else %}bg-secondary{% endif %}">
                                    {{ player.rankPointGame }}
                                </span>
                            </td>
                            <td>
                                <a href="{{ path('vgr_player_profile_overview', {id: player.id, slug: player.slug}) }}" class="text-decoration-none" data-turbo-prefetch="false">
                                    {% if loop.index == 1 %}<strong>{% endif %}
                                    {{ player.pseudo }}
                                    {% if loop.index == 1 %}</strong>{% endif %}
                                </a>
                            </td>
                            <td class="text-end">{{ player.pointGame|number_format(0, '.', ',') }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">
                                No players found
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
