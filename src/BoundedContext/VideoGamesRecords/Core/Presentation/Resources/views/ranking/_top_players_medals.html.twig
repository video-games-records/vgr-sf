<div class="card border shadow-sm h-100">
    <div class="card-header border-bottom">
        <h5 class="mb-0"><i class="bi bi-award"></i> Medals</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 50px;">#</th>
                        <th>Player</th>
                        <th class="text-center" style="width: 60px;" title="Platine"><i class="bi bi-award text-platinum"></i></th>
                        <th class="text-center" style="width: 60px;" title="Or"><i class="bi bi-award text-gold"></i></th>
                        <th class="text-center" style="width: 60px;" title="Argent"><i class="bi bi-award text-silver"></i></th>
                        <th class="text-center" style="width: 60px;" title="Bronze"><i class="bi bi-award text-bronze"></i></th>
                    </tr>
                </thead>
                <tbody>
                    {% for player in players %}
                        <tr>
                            <td class="text-center">
                                <span class="badge rounded-pill {% if loop.index == 1 %}bg-warning text-dark{% else %}bg-secondary{% endif %}">
                                    {{ player.rankMedal }}
                                </span>
                            </td>
                            <td>
                                <a href="{{ path('vgr_player_profile_overview', {id: player.id, slug: player.slug}) }}" class="text-decoration-none" data-turbo-prefetch="false">
                                    {% if loop.index == 1 %}<strong>{% endif %}
                                    {{ player.pseudo }}
                                    {% if loop.index == 1 %}</strong>{% endif %}
                                </a>
                            </td>
                            <td class="text-center text-platinum">{{ player.chartRank0 }}</td>
                            <td class="text-center text-gold">{{ player.chartRank1 }}</td>
                            <td class="text-center text-silver">{{ player.chartRank2 }}</td>
                            <td class="text-center text-bronze">{{ player.chartRank3 }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                No players found
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
