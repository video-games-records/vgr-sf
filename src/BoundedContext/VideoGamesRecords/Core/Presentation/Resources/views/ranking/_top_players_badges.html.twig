<div class="card border shadow-sm h-100">
    <div class="card-header border-bottom">
        <h5 class="mb-0"><i class="bi bi-patch-check"></i> Badges</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 50px;">#</th>
                        <th>Player</th>
                        <th class="text-end" style="width: 70px;" title="Points">Pts</th>
                        <th class="text-center" style="width: 60px;" title="Master Badges"><i class="bi bi-star-fill"></i></th>
                    </tr>
                </thead>
                <tbody>
                    {% for player in players %}
                        <tr>
                            <td class="text-center">
                                <span class="badge rounded-pill {% if loop.index == 1 %}bg-warning text-dark{% else %}bg-secondary{% endif %}">
                                    {{ player.rankBadge }}
                                </span>
                            </td>
                            <td>
                                {{ component('player_link', {
                                    player: player,
                                    showTeam: false,
                                    showCountry: false
                                }) }}
                            </td>
                            <td class="text-end">{{ player.pointBadge|number_format(0, '.', ',') }}</td>
                            <td class="text-end"><span class="badge bg-primary">{{ player.nbMasterBadge }}</span></td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                No players found
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
