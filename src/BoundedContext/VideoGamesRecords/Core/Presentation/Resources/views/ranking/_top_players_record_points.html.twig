<div class="card border shadow-sm h-100">
    <div class="card-header border-bottom">
        <h5 class="mb-0"><i class="bi bi-graph-up-arrow"></i> Record Points</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 50px;">#</th>
                        <th>Player</th>
                        <th class="text-end">Points</th>
                        {% if showNbChart|default(false) %}
                            <th class="text-center">Records</th>
                        {% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for player in players %}
                        <tr>
                            <td class="text-center">
                                <span class="badge rounded-pill {% if loop.index == 1 %}bg-warning text-dark{% else %}bg-secondary{% endif %}">
                                    {{ player.rankPointChart }}
                                </span>
                            </td>
                            <td>
                                {{ component('player_link', {
                                    player: player,
                                    bold: loop.index == 1,
                                    showTeam: false,
                                    showCountry: false
                                }) }}
                            </td>
                            <td class="text-end">{{ player.pointChart|number_format(0, '.', ',') }}</td>
                            {% if showNbChart|default(false) %}
                                <td class="text-center">{{ player.nbChart }}</td>
                            {% endif %}
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="{{ showNbChart|default(false) ? 4 : 3 }}" class="text-center text-muted py-4">
                                No players found
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
