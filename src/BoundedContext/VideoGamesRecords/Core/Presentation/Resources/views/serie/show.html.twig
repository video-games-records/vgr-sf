{% extends '@SharedKernel/base.html.twig' %}
{% trans_default_domain 'VgrCore' %}

{% block title %}{{ serie.libSerie }} - {{ 'serie.show.title'|trans }}{% endblock %}

{% block meta_description %}{{ 'serie.show.meta_description'|trans({'%serie%': serie.libSerie}) }}{% endblock %}

{% block body %}
<div class="container py-4">
    {# Include common serie header #}
    {% include '@VideoGamesRecordsCore/serie/_header.html.twig' with {
        'serie': serie
    } %}

    {# Tabs Navigation #}
    <ul class="nav nav-tabs mb-4" id="serieTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link {{ activeTab == 'games' ? 'active' : '' }}"
                    id="games-tab"
                    data-bs-toggle="tab"
                    data-bs-target="#games"
                    type="button"
                    role="tab"
                    aria-controls="games"
                    aria-selected="{{ activeTab == 'games' ? 'true' : 'false' }}">
                <i class="bi bi-joystick"></i> {{ 'serie.show.tab_games'|trans }}
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link {{ activeTab == 'leaderboard-points' ? 'active' : '' }}"
                    id="leaderboard-points-tab"
                    data-bs-toggle="tab"
                    data-bs-target="#leaderboard-points"
                    type="button"
                    role="tab"
                    aria-controls="leaderboard-points"
                    aria-selected="{{ activeTab == 'leaderboard-points' ? 'true' : 'false' }}">
                <i class="bi bi-trophy"></i> {{ 'serie.show.tab_leaderboard_points'|trans }}
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link {{ activeTab == 'leaderboard-medals' ? 'active' : '' }}"
                    id="leaderboard-medals-tab"
                    data-bs-toggle="tab"
                    data-bs-target="#leaderboard-medals"
                    type="button"
                    role="tab"
                    aria-controls="leaderboard-medals"
                    aria-selected="{{ activeTab == 'leaderboard-medals' ? 'true' : 'false' }}">
                <i class="bi bi-award"></i> {{ 'serie.show.tab_leaderboard_medals'|trans }}
            </button>
        </li>
    </ul>

    {# Tab Content #}
    <div class="tab-content" id="serieTabsContent">
        {# Games Tab #}
        <div class="tab-pane fade {{ activeTab == 'games' ? 'show active' : '' }}"
             id="games"
             role="tabpanel"
             aria-labelledby="games-tab">

            {% if games|length > 0 %}
                <div class="card shadow-sm">
                    <div class="list-group list-group-flush">
                        {% for game in games %}
                            <a href="{{ path('vgr_game_show', {id: game.id, slug: game.slug}) }}"
                               class="list-group-item list-group-item-action py-2"
                               data-turbo-prefetch="false">
                                <div class="row align-items-center g-2">
                                    {# Game Image #}
                                    <div class="col-auto">
                                        <img
                                            src="{{ path('vgr_core_game_picture', {id: game.id}) }}"
                                            alt="{{ game.name }}"
                                            class="rounded"
                                            width="50"
                                            height="50"
                                            style="object-fit: cover;"
                                        >
                                    </div>

                                    {# Game Info #}
                                    <div class="col">
                                        <h6 class="mb-0">{{ game.name }}</h6>
                                    </div>

                                    {# Game Stats #}
                                    <div class="col-auto d-none d-md-block">
                                        <div class="d-flex gap-3 text-muted" style="font-size: 0.75rem;">
                                            {% if game.nbChart is defined and game.nbChart > 0 %}
                                                <span>
                                                    <i class="bi bi-bar-chart"></i>
                                                    {{ game.nbChart }}
                                                </span>
                                            {% endif %}
                                            {% if game.nbPlayer is defined and game.nbPlayer > 0 %}
                                                <span>
                                                    <i class="bi bi-people"></i>
                                                    {{ game.nbPlayer }}
                                                </span>
                                            {% endif %}
                                            {% if game.nbPost is defined and game.nbPost > 0 %}
                                                <span>
                                                    <i class="bi bi-trophy"></i>
                                                    {{ game.nbPost }}
                                                </span>
                                            {% endif %}
                                        </div>
                                    </div>

                                    {# Arrow Icon #}
                                    <div class="col-auto">
                                        <i class="bi bi-chevron-right text-muted"></i>
                                    </div>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% else %}
                <div class="card shadow-sm">
                    <div class="card-body text-center text-muted py-5">
                        <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                        <p class="mt-3 mb-0">{{ 'serie.show.no_games'|trans }}</p>
                    </div>
                </div>
            {% endif %}
        </div>

        {# Leaderboard Points Tab #}
        <div class="tab-pane fade {{ activeTab == 'leaderboard-points' ? 'show active' : '' }}"
             id="leaderboard-points"
             role="tabpanel"
             aria-labelledby="leaderboard-points-tab">

            {% if rankingsPoints|length > 0 %}
                <div class="card shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th class="text-center" style="width: 80px;">{{ 'serie.leaderboard.rank'|trans }}</th>
                                    <th>{{ 'serie.leaderboard.player'|trans }}</th>
                                    <th class="text-end">{{ 'serie.leaderboard.points'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for playerSerie in rankingsPoints %}
                                    <tr {% if app.user and playerSerie.player.getUserId() == app.user.id %}class="table-primary"{% endif %}>
                                        <td class="text-center">
                                            <strong>#{{ playerSerie.rankPointChart }}</strong>
                                        </td>
                                        <td>
                                            {{ component('player_link', {
                                                player: playerSerie.player,
                                                bold: false,
                                                showTeam: false,
                                                showCountry: false
                                            }) }}
                                        </td>
                                        <td class="text-end">
                                            <strong>{{ playerSerie.pointChart|number_format(0, '.', ',') }}</strong>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% else %}
                <div class="card shadow-sm">
                    <div class="card-body text-center text-muted py-5">
                        <i class="bi bi-trophy" style="font-size: 3rem;"></i>
                        <p class="mt-3 mb-0">{{ 'serie.show.no_rankings'|trans }}</p>
                    </div>
                </div>
            {% endif %}
        </div>

        {# Leaderboard Medals Tab #}
        <div class="tab-pane fade {{ activeTab == 'leaderboard-medals' ? 'show active' : '' }}"
             id="leaderboard-medals"
             role="tabpanel"
             aria-labelledby="leaderboard-medals-tab">

            {% if rankingsMedals|length > 0 %}
                <div class="card shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th class="text-center" style="width: 80px;">{{ 'serie.leaderboard.rank'|trans }}</th>
                                    <th>{{ 'serie.leaderboard.player'|trans }}</th>
                                    <th class="text-center" style="width: 60px;"><i class="bi bi-award text-platinum"></i></th>
                                    <th class="text-center" style="width: 60px;"><i class="bi bi-award text-gold"></i></th>
                                    <th class="text-center" style="width: 60px;"><i class="bi bi-award text-silver"></i></th>
                                    <th class="text-center" style="width: 60px;"><i class="bi bi-award text-bronze"></i></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for playerSerie in rankingsMedals %}
                                    <tr {% if app.user and playerSerie.player.getUserId() == app.user.id %}class="table-primary"{% endif %}>
                                        <td class="text-center">
                                            <strong>#{{ playerSerie.rankMedal }}</strong>
                                        </td>
                                        <td>
                                            {{ component('player_link', {
                                                player: playerSerie.player,
                                                bold: false,
                                                showTeam: false,
                                                showCountry: false
                                            }) }}
                                        </td>
                                        <td class="text-center text-platinum">{{ playerSerie.chartRank0 }}</td>
                                        <td class="text-center text-gold">{{ playerSerie.chartRank1 }}</td>
                                        <td class="text-center text-silver">{{ playerSerie.chartRank2 }}</td>
                                        <td class="text-center text-bronze">{{ playerSerie.chartRank3 }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% else %}
                <div class="card shadow-sm">
                    <div class="card-body text-center text-muted py-5">
                        <i class="bi bi-award" style="font-size: 3rem;"></i>
                        <p class="mt-3 mb-0">{{ 'serie.show.no_rankings'|trans }}</p>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
