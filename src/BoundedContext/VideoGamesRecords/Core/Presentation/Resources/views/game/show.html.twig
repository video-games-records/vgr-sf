{% extends '@SharedKernel/base.html.twig' %}
{% trans_default_domain 'VgrCore' %}

{% block title %}{{ game.name }} - {{ 'game.show.title'|trans }}{% endblock %}

{% block meta_description %}{{ 'game.show.meta_description'|trans({'%game%': game.name}) }}{% endblock %}

{% block body %}
<div class="container py-4">
    {# Include common game header #}
    {% include '@VideoGamesRecordsCore/game/_header.html.twig' with {
        'game': game
    } %}

    {# Submit Scores Button #}
    {% if is_granted('ROLE_USER') %}
        <div class="mb-4">
            <a href="{{ path('vgr_game_scores', {id: game.id, slug: game.slug}) }}" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> {{ 'game.show.submit_scores'|trans }}
            </a>
        </div>
    {% endif %}

    {# Game Summary (if available from IGDB) - Hidden on mobile #}
    {% if game.summary %}
        <div class="card mb-4 d-none d-md-block">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-info-circle"></i> {{ 'game.show.about'|trans }}
                </h5>
                <p class="card-text">{{ game.summary }}</p>
            </div>
        </div>
    {% endif %}

    {# Groups List #}
    <div class="card shadow-sm">
        <div class="card-header border-bottom">
            <h5 class="mb-0">
                <i class="bi bi-collection"></i> {{ 'game.show.groups_title'|trans }}
            </h5>
        </div>

        {% if game.groups|length > 0 %}
            <div class="list-group list-group-flush">
                {% for group in game.groups %}
                    <a href="{{ path('vgr_group_show', {id: game.id, slug: game.slug, groupId: group.id, groupSlug: group.slug}) }}" class="list-group-item list-group-item-action">
                        <div class="d-flex w-100 justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1">
                                    {{ group.name }}
                                    {% if group.isDlc %}
                                        <span class="badge bg-info">
                                            <i class="bi bi-download"></i> DLC
                                        </span>
                                    {% endif %}
                                </h6>
                                <p class="mb-1 text-muted small">
                                    <i class="bi bi-bar-chart"></i>
                                    {% if group.nbChart is defined and group.nbChart > 0 %}
                                        {{ group.nbChart }} {{ 'game.show.charts'|trans }}
                                    {% else %}
                                        {{ 'game.show.no_charts'|trans }}
                                    {% endif %}

                                    {% if group.nbPlayer is defined and group.nbPlayer > 0 %}
                                        <span class="ms-3">
                                            <i class="bi bi-people"></i>
                                            {{ group.nbPlayer }} {{ 'game.show.players'|trans }}
                                        </span>
                                    {% endif %}

                                    {% if group.nbPost is defined and group.nbPost > 0 %}
                                        <span class="ms-3">
                                            <i class="bi bi-trophy"></i>
                                            {{ group.nbPost }} {{ 'game.show.scores'|trans }}
                                        </span>
                                    {% endif %}
                                </p>
                            </div>
                            <div>
                                <i class="bi bi-chevron-right"></i>
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% else %}
            <div class="card-body text-center text-muted py-5">
                <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                <p class="mt-3 mb-0">{{ 'game.show.no_groups'|trans }}</p>
            </div>
        {% endif %}
    </div>

    {# Additional Game Information #}
    {% if game.storyline or game.downloadUrl %}
        <div class="row mt-4">
            {# Storyline #}
            {% if game.storyline %}
                <div class="col-md-8">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-book"></i> {{ 'game.show.storyline'|trans }}
                            </h5>
                            <p class="card-text">{{ game.storyline }}</p>
                        </div>
                    </div>
                </div>
            {% endif %}

            {# Download Link #}
            {% if game.downloadUrl %}
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body text-center">
                            <h5 class="card-title">
                                <i class="bi bi-download"></i> {{ 'game.show.download'|trans }}
                            </h5>
                            <a href="{{ game.downloadUrl }}" class="btn btn-primary" target="_blank" rel="noopener">
                                <i class="bi bi-box-arrow-up-right"></i> {{ 'game.show.download_button'|trans }}
                            </a>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    {% endif %}

    {# Game Rankings #}
    <div class="card shadow-sm mt-4">
        <div class="card-header border-bottom">
            <h5 class="mb-0">
                <i class="bi bi-trophy"></i> {{ 'game.show.rankings_title'|trans }}
            </h5>
        </div>
        <div class="card-body p-0">
            {# Navigation Tabs #}
            <ul class="nav nav-tabs px-3 pt-3" id="gameRankingTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="player-points-tab" data-bs-toggle="tab" data-bs-target="#player-points-pane" type="button" role="tab" aria-controls="player-points-pane" aria-selected="true">
                        <i class="bi bi-person"></i> {{ 'game.show.rankings.player_points'|trans }}
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="player-medals-tab" data-bs-toggle="tab" data-bs-target="#player-medals-pane" type="button" role="tab" aria-controls="player-medals-pane" aria-selected="false">
                        <i class="bi bi-person"></i> {{ 'game.show.rankings.player_medals'|trans }}
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="team-points-tab" data-bs-toggle="tab" data-bs-target="#team-points-pane" type="button" role="tab" aria-controls="team-points-pane" aria-selected="false">
                        <i class="bi bi-people"></i> {{ 'game.show.rankings.team_points'|trans }}
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="team-medals-tab" data-bs-toggle="tab" data-bs-target="#team-medals-pane" type="button" role="tab" aria-controls="team-medals-pane" aria-selected="false">
                        <i class="bi bi-people"></i> {{ 'game.show.rankings.team_medals'|trans }}
                    </button>
                </li>
            </ul>

            {# Tab Content #}
            <div class="tab-content" id="gameRankingTabsContent">
                {# Player Points Tab #}
                <div class="tab-pane fade show active" id="player-points-pane" role="tabpanel" aria-labelledby="player-points-tab">
                    {{ render(controller(
                        'App\\BoundedContext\\VideoGamesRecords\\Core\\Presentation\\Web\\Controller\\Ranking\\PlayerGameRankingController::points',
                        {gameId: game.id, limit: 100}
                    )) }}
                </div>

                {# Player Medals Tab #}
                <div class="tab-pane fade" id="player-medals-pane" role="tabpanel" aria-labelledby="player-medals-tab">
                    {{ render(controller(
                        'App\\BoundedContext\\VideoGamesRecords\\Core\\Presentation\\Web\\Controller\\Ranking\\PlayerGameRankingController::medals',
                        {gameId: game.id, limit: 100}
                    )) }}
                </div>

                {# Team Points Tab #}
                <div class="tab-pane fade" id="team-points-pane" role="tabpanel" aria-labelledby="team-points-tab">
                    {{ render(controller(
                        'App\\BoundedContext\\VideoGamesRecords\\Team\\Presentation\\Web\\Controller\\Ranking\\TeamGameRankingController::points',
                        {gameId: game.id, limit: 100}
                    )) }}
                </div>

                {# Team Medals Tab #}
                <div class="tab-pane fade" id="team-medals-pane" role="tabpanel" aria-labelledby="team-medals-tab">
                    {{ render(controller(
                        'App\\BoundedContext\\VideoGamesRecords\\Team\\Presentation\\Web\\Controller\\Ranking\\TeamGameRankingController::medals',
                        {gameId: game.id, limit: 100}
                    )) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
