<div class="card border shadow-sm h-100">
    <div class="card-header border-bottom">
        <h5 class="mb-0"><i class="bi bi-controller"></i> {{ 'game.latest.card_title'|trans({}, 'VgrCore') }}</h5>
    </div>
    <div class="card-body p-0">
        <div class="list-group list-group-flush">
            {% for game in games %}
                <a href="{{ path('vgr_game_show', {id: game.id, slug: game.slug}) }}" class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <span class="text-truncate me-2">{{ game.name }}</span>
                        <small class="text-muted text-nowrap">{{ game.publishedAt|date('M d') }}</small>
                    </div>
                </a>
            {% else %}
                <div class="list-group-item text-center text-muted py-4">
                    {{ 'game.latest.no_games_card'|trans({}, 'VgrCore') }}
                </div>
            {% endfor %}
        </div>
    </div>
</div>
