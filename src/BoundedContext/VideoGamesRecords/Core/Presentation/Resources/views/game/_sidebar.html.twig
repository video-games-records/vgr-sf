{# Sidebar for game, group, chart, and score pages #}
{# Parameters: game (required) #}
{% trans_default_domain 'VgrCore' %}

{# Links Card #}
<div class="card shadow-sm">
    <div class="card-header border-bottom">
        <h5 class="mb-0">
            <i class="bi bi-link-45deg"></i> {{ 'sidebar.title'|trans }}
        </h5>
    </div>
    <div class="list-group list-group-flush">
        {# Forum Link #}
        {% if game.forum is defined and game.forum %}
            <a href="{{ path('forum_show', {id: game.forum.id, slug: game.forum.slug}) }}" class="list-group-item list-group-item-action">
                <div class="d-flex align-items-center">
                    <i class="bi bi-chat-dots me-3 fs-5 text-primary"></i>
                    <div>
                        <div class="fw-bold">{{ 'sidebar.forum'|trans }}</div>
                        <small class="text-muted">{{ 'sidebar.forum_description'|trans }}</small>
                    </div>
                </div>
            </a>
        {% endif %}

        {# Serie Link #}
        {% if game.serie is defined and game.serie %}
            <a href="{{ path('vgr_serie_show', {id: game.serie.id, slug: game.serie.slug}) }}" class="list-group-item list-group-item-action">
                <div class="d-flex align-items-center">
                    <i class="bi bi-collection me-3 fs-5 text-success"></i>
                    <div>
                        <div class="fw-bold">{{ game.serie.name }}</div>
                        <small class="text-muted">{{ 'sidebar.serie_description'|trans }}</small>
                    </div>
                </div>
            </a>
        {% endif %}

        {# General Rules Link #}
        <a href="{{ path('static_rules') }}" class="list-group-item list-group-item-action">
            <div class="d-flex align-items-center">
                <i class="bi bi-journal-text me-3 fs-5 text-warning"></i>
                <div>
                    <div class="fw-bold">{{ 'sidebar.rules'|trans }}</div>
                    <small class="text-muted">{{ 'sidebar.rules_description'|trans }}</small>
                </div>
            </div>
        </a>
    </div>
</div>

{# Game Specific Rules Card #}
{% if game.rules is defined and game.rules|length > 0 %}
    <div class="card shadow-sm mt-4">
        <div class="card-header border-bottom">
            <h5 class="mb-0">
                <i class="bi bi-exclamation-triangle text-warning"></i> {{ 'sidebar.game_rules_title'|trans }}
            </h5>
        </div>
        <div class="card-body">
            {% for rule in game.rules %}
                <div class="{% if not loop.last %}mb-3 pb-3 border-bottom{% endif %}">
                    <h6 class="fw-bold text-primary mb-2">
                        <i class="bi bi-check-circle me-1"></i>{{ rule.name }}
                    </h6>
                    <div class="small">
                        {{ rule.getContent(app.request.locale)|raw }}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endif %}
