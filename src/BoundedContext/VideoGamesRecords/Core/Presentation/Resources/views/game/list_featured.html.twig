{% extends '@SharedKernel/base.html.twig' %}
{% trans_default_domain 'VgrCore' %}

{% block title %}{{ 'game.featured.title'|trans }}{% endblock %}

{% block meta_description %}{{ 'game.featured.meta_description'|trans }}{% endblock %}

{% block body %}
<div class="container py-4">
    {# Breadcrumb Navigation #}
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('home') }}">
                    <i class="bi bi-house"></i> {{ 'breadcrumb.home'|trans }}
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                {{ 'game.featured.breadcrumb'|trans }}
            </li>
        </ol>
    </nav>

    {# Page Header #}
    <div class="mb-4">
        <h1 class="h3">
            <i class="bi bi-star"></i>
            {{ 'game.featured.header'|trans }}
        </h1>
        <p class="text-muted">{{ 'game.featured.description'|trans }}</p>
    </div>

    {# COMPLETED - Ready to be activated #}
    {% if gamesCompleted|length > 0 %}
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">
                    <i class="bi bi-check-circle"></i>
                    {{ 'game.featured.status_completed'|trans }}
                    <span class="badge bg-light text-success ms-2">{{ gamesCompleted|length }}</span>
                </h5>
                <small>{{ 'game.featured.status_completed_desc'|trans }}</small>
            </div>
            <div class="list-group list-group-flush">
                {% for game in gamesCompleted %}
                    {{ _self.game_item(game) }}
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# ADD_PICTURE - Adding images #}
    {% if gamesAddPicture|length > 0 %}
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">
                    <i class="bi bi-image"></i>
                    {{ 'game.featured.status_add_picture'|trans }}
                    <span class="badge bg-light text-info ms-2">{{ gamesAddPicture|length }}</span>
                </h5>
                <small>{{ 'game.featured.status_add_picture_desc'|trans }}</small>
            </div>
            <div class="list-group list-group-flush">
                {% for game in gamesAddPicture %}
                    {{ _self.game_item(game) }}
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# ADD_SCORE - Adding records #}
    {% if gamesAddScore|length > 0 %}
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">
                    <i class="bi bi-trophy"></i>
                    {{ 'game.featured.status_add_score'|trans }}
                    <span class="badge bg-light text-warning ms-2">{{ gamesAddScore|length }}</span>
                </h5>
                <small>{{ 'game.featured.status_add_score_desc'|trans }}</small>
            </div>
            <div class="list-group list-group-flush">
                {% for game in gamesAddScore %}
                    {{ _self.game_item(game) }}
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# CREATED - Just created #}
    {% if gamesCreated|length > 0 %}
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0">
                    <i class="bi bi-plus-circle"></i>
                    {{ 'game.featured.status_created'|trans }}
                    <span class="badge bg-light text-secondary ms-2">{{ gamesCreated|length }}</span>
                </h5>
                <small>{{ 'game.featured.status_created_desc'|trans }}</small>
            </div>
            <div class="list-group list-group-flush">
                {% for game in gamesCreated %}
                    {{ _self.game_item(game) }}
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# No games at all #}
    {% if gamesCreated|length == 0 and gamesAddScore|length == 0 and gamesAddPicture|length == 0 and gamesCompleted|length == 0 %}
        <div class="card shadow-sm">
            <div class="card-body text-center text-muted py-5">
                <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                <p class="mt-3 mb-0">{{ 'game.featured.no_games'|trans }}</p>
            </div>
        </div>
    {% endif %}
</div>

{# Macro for game item (no link since game is not active) #}
{% macro game_item(game) %}
    <div class="list-group-item py-2">
        <div class="row align-items-center g-2">
            {# Game Image #}
            <div class="col-auto">
                <img
                    src="{{ path('vgr_core_game_picture', {id: game.id, v: game.updatedAt|date('U')}) }}"
                    alt="{{ game.name }}"
                    class="rounded"
                    width="50"
                    height="50"
                    style="object-fit: cover;"
                >
            </div>

            {# Game Info #}
            <div class="col">
                <h6 class="mb-1">{{ game.name }}</h6>

                {# Platforms #}
                {% if game.platforms|length > 0 %}
                    <div class="d-flex flex-wrap gap-1">
                        {% for platform in game.platforms|slice(0, 5) %}
                            <span class="platform-badge platform-badge--{{ platform.id }}">{{ platform.name }}</span>
                        {% endfor %}
                        {% if game.platforms|length > 5 %}
                            <span class="platform-badge">+{{ game.platforms|length - 5 }}</span>
                        {% endif %}
                    </div>
                {% endif %}
            </div>

            {# Game Stats #}
            <div class="col-auto d-none d-md-block">
                <div class="d-flex gap-3 text-muted" style="font-size: 0.75rem;">
                    {% if game.nbChart is defined and game.nbChart > 0 %}
                        <span>
                            <i class="bi bi-bar-chart"></i>
                            {{ game.nbChart }}
                        </span>
                    {% endif %}
                    {% if game.nbPlayer is defined and game.nbPlayer > 0 %}
                        <span>
                            <i class="bi bi-people"></i>
                            {{ game.nbPlayer }}
                        </span>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endmacro %}
{% endblock %}
