{% extends '@SharedKernel/base.html.twig' %}
{% trans_default_domain 'VgrCore' %}

{% block title %}{{ 'leaderboard.cups.page_title'|trans }}{% endblock %}

{% block body %}
<div class="container py-4">

    <div class="row">
        <div class="col-12">
            <div class="card border shadow-sm">
                <div class="card-header border-bottom">
                    <h5 class="mb-0"><i class="bi bi-trophy"></i> {{ 'leaderboard.cups.title'|trans }}</h5>
                </div>
                <div class="card-body p-0">
                    {# Navigation Tabs #}
                    <ul class="nav nav-tabs px-3 pt-3" id="leaderboardTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="players-tab" data-bs-toggle="tab" data-bs-target="#players-pane" type="button" role="tab" aria-controls="players-pane" aria-selected="true">
                                <i class="bi bi-person"></i> {{ 'leaderboard.tabs.players'|trans }}
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="teams-tab" data-bs-toggle="tab" data-bs-target="#teams-pane" type="button" role="tab" aria-controls="teams-pane" aria-selected="false">
                                <i class="bi bi-people"></i> {{ 'leaderboard.tabs.teams'|trans }}
                            </button>
                        </li>
                    </ul>

                    {# Tab Content #}
                    <div class="tab-content" id="leaderboardTabsContent">
                        {# Players Tab #}
                        <div class="tab-pane fade show active" id="players-pane" role="tabpanel" aria-labelledby="players-tab">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th class="text-center" style="width: 60px;">{{ 'leaderboard.columns.rank'|trans }}</th>
                                            <th class="d-none d-md-table-cell" style="width: 60px;"></th>
                                            <th>{{ 'leaderboard.columns.player'|trans }}</th>
                                            <th class="text-center" style="width: 80px;" title="{{ 'player.profile.achievements.platinum'|trans }}"><i class="bi bi-trophy-fill text-platinum"></i></th>
                                            <th class="text-center" style="width: 80px;" title="{{ 'player.profile.achievements.gold'|trans }}"><i class="bi bi-trophy-fill text-gold"></i></th>
                                            <th class="text-center" style="width: 80px;" title="{{ 'player.profile.achievements.silver'|trans }}"><i class="bi bi-trophy-fill text-silver"></i></th>
                                            <th class="text-center" style="width: 80px;" title="{{ 'player.profile.achievements.bronze'|trans }}"><i class="bi bi-trophy-fill text-bronze"></i></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for player in players %}
                                            <tr {% if app.user and player.getUserId() == app.user.id %}class="table-primary"{% endif %}>
                                                <td class="text-center align-middle">
                                                    <span class="badge rounded-pill {% if loop.index <= 3 %}bg-warning text-dark{% else %}bg-secondary{% endif %}">
                                                        {{ player.rankCup }}
                                                    </span>
                                                </td>
                                                <td class="align-middle d-none d-md-table-cell">
                                                    <img src="/users/{{ player.getUserId() }}/avatar"
                                                         alt="{{ player.pseudo }}"
                                                         class="rounded-circle"
                                                         width="40"
                                                         height="40">
                                                </td>
                                                <td class="align-middle">
                                                    {{ component('player_link', {
                                                        player: player,
                                                        bold: loop.index <= 3,
                                                        showTeam: true,
                                                        showCountry: true,
                                                        showAvatar: false
                                                    }) }}
                                                </td>
                                                <td class="text-center align-middle">
                                                    {{ player.gameRank0 }}
                                                </td>
                                                <td class="text-center align-middle">
                                                    {{ player.gameRank1 }}
                                                </td>
                                                <td class="text-center align-middle">
                                                    {{ player.gameRank2 }}
                                                </td>
                                                <td class="text-center align-middle">
                                                    {{ player.gameRank3 }}
                                                </td>
                                            </tr>
                                        {% else %}
                                            <tr>
                                                <td colspan="7" class="text-center text-muted py-4">
                                                    {{ 'leaderboard.no_players'|trans }}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        {# Teams Tab #}
                        <div class="tab-pane fade" id="teams-pane" role="tabpanel" aria-labelledby="teams-tab">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th class="text-center" style="width: 60px;">{{ 'leaderboard.columns.rank'|trans }}</th>
                                            <th class="d-none d-md-table-cell" style="width: 60px;"></th>
                                            <th>{{ 'leaderboard.columns.team'|trans }}</th>
                                            <th class="text-center" style="width: 80px;" title="{{ 'player.profile.achievements.platinum'|trans }}"><i class="bi bi-trophy-fill text-platinum"></i></th>
                                            <th class="text-center" style="width: 80px;" title="{{ 'player.profile.achievements.gold'|trans }}"><i class="bi bi-trophy-fill text-gold"></i></th>
                                            <th class="text-center" style="width: 80px;" title="{{ 'player.profile.achievements.silver'|trans }}"><i class="bi bi-trophy-fill text-silver"></i></th>
                                            <th class="text-center" style="width: 80px;" title="{{ 'player.profile.achievements.bronze'|trans }}"><i class="bi bi-trophy-fill text-bronze"></i></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for team in teams %}
                                            <tr>
                                                <td class="text-center align-middle">
                                                    <span class="badge rounded-pill {% if loop.index <= 3 %}bg-warning text-dark{% else %}bg-secondary{% endif %}">
                                                        {{ team.rankCup }}
                                                    </span>
                                                </td>
                                                <td class="align-middle d-none d-md-table-cell">
                                                    <img src="/teams/{{ team.id }}/avatar"
                                                         alt="{{ team.libTeam }}"
                                                         class="rounded-circle"
                                                         width="40"
                                                         height="40">
                                                </td>
                                                <td class="align-middle">
                                                    <a href="{{ path('vgr_team_profile_overview', {id: team.id, slug: team.slug}) }}"
                                                       class="text-decoration-none{% if loop.index <= 3 %} fw-bold{% endif %}">
                                                        [{{ team.tag }}] {{ team.libTeam }}
                                                    </a>
                                                </td>
                                                <td class="text-center align-middle">
                                                    {{ team.gameRank0 }}
                                                </td>
                                                <td class="text-center align-middle">
                                                    {{ team.gameRank1 }}
                                                </td>
                                                <td class="text-center align-middle">
                                                    {{ team.gameRank2 }}
                                                </td>
                                                <td class="text-center align-middle">
                                                    {{ team.gameRank3 }}
                                                </td>
                                            </tr>
                                        {% else %}
                                            <tr>
                                                <td colspan="7" class="text-center text-muted py-4">
                                                    {{ 'leaderboard.no_teams'|trans }}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
