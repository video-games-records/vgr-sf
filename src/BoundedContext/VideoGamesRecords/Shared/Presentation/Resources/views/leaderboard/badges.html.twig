{% extends '@SharedKernel/base.html.twig' %}

{% block title %}Badges Leaderboard - Video Games Records{% endblock %}

{% block body %}
<div class="container py-4">

    <div class="row">
        <div class="col-12">
            <div class="card border shadow-sm">
                <div class="card-header border-bottom">
                    <h5 class="mb-0"><i class="bi bi-patch-check"></i> Badges Leaderboard</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th class="text-center" style="width: 60px;">#</th>
                                    <th class="d-none d-md-table-cell" style="width: 60px;"></th>
                                    <th>Player</th>
                                    <th class="text-end" style="width: 120px;">Points</th>
                                    <th class="text-center" style="width: 100px;" title="Master Badges"><i class="bi bi-star-fill"></i></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for player in players %}
                                    <tr {% if app.user and player.getUserId() == app.user.id %}class="table-primary"{% endif %}>
                                        <td class="text-center align-middle">
                                            <span class="badge rounded-pill {% if loop.index <= 3 %}bg-warning text-dark{% else %}bg-secondary{% endif %}">
                                                {{ player.rankBadge }}
                                            </span>
                                        </td>
                                        <td class="align-middle d-none d-md-table-cell">
                                            <img src="/users/{{ player.getUserId() }}/avatar"
                                                 alt="{{ player.pseudo }}"
                                                 class="rounded-circle"
                                                 width="40"
                                                 height="40">
                                        </td>
                                        <td class="align-middle">
                                            <div class="d-flex align-items-center gap-2">
                                                {% if player.team %}
                                                    <span>[{{ player.team.tag }}]</span>
                                                {% endif %}
                                                <a href="{{ path('vgr_player_profile_overview', {id: player.id, slug: player.slug}) }}" {% if loop.index <= 3 %}class="fw-bold text-decoration-none"{% else %}class="text-decoration-none"{% endif %} data-turbo-prefetch="false">
                                                    {{ player.pseudo }}
                                                </a>
                                                {% if player.country %}
                                                    <img src="https://flagcdn.com/20x15/{{ player.country.codeIso2|lower }}.png"
                                                         alt="{{ player.country.name }}"
                                                         title="{{ player.country.name }}">
                                                {% endif %}
                                            </div>
                                        </td>
                                        <td class="text-end align-middle {% if loop.index <= 3 %}fw-bold{% endif %}">
                                            {{ player.pointBadge|number_format(0, '.', ',') }}
                                        </td>
                                        <td class="text-center align-middle">
                                            <span class="badge bg-primary">{{ player.nbMasterBadge }}</span>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">
                                            No players found
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
