{% extends '@SharedKernel/base.html.twig' %}

{% block title %}Game Points Leaderboard - Video Games Records{% endblock %}

{% block body %}
<div class="container py-4">

    <div class="row">
        <div class="col-12">
            <div class="card border shadow-sm">
                <div class="card-header border-bottom">
                    <h5 class="mb-0"><i class="bi bi-graph-up-arrow"></i> Game Points Leaderboard</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th class="text-center" style="width: 60px;">#</th>
                                    <th class="d-none d-md-table-cell" style="width: 60px;"></th>
                                    <th>Player</th>
                                    <th class="text-end" style="width: 150px;">Points</th>
                                    <th class="text-center" style="width: 80px;">Games</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for player in players %}
                                    <tr {% if app.user and player.getUserId() == app.user.id %}class="table-primary"{% endif %}>
                                        <td class="text-center align-middle">
                                            <span class="badge rounded-pill {% if loop.index <= 3 %}bg-warning text-dark{% else %}bg-secondary{% endif %}">
                                                {{ player.rankPointGame }}
                                            </span>
                                        </td>
                                        <td class="align-middle d-none d-md-table-cell">
                                            <img src="/users/{{ player.getUserId() }}/avatar"
                                                 alt="{{ player.pseudo }}"
                                                 class="rounded-circle"
                                                 width="40"
                                                 height="40">
                                        </td>
                                        <td class="align-middle">
                                            {{ component('player_link', {
                                                player: player,
                                                bold: loop.index <= 3,
                                                showTeam: true,
                                                showCountry: true,
                                                showAvatar: false
                                            }) }}
                                        </td>
                                        <td class="text-end align-middle {% if loop.index <= 3 %}fw-bold{% endif %}">
                                            {{ player.pointGame|number_format(0, '.', ',') }}
                                        </td>
                                        <td class="text-center align-middle">
                                            <span class="badge bg-primary">{{ player.nbGame }}</span>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">
                                            No players found
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
