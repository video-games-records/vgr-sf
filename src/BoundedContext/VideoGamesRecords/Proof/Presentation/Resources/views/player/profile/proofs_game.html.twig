{% extends '@VideoGamesRecordsCore/player/profile/_base.html.twig' %}
{% trans_default_domain 'VgrCore' %}

{% block profile_content %}
<div class="row">
    <div class="col-12">
        <div class="mb-3">
            <a href="{{ path('vgr_player_profile_proofs', {id: player.id, slug: player.slug}) }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> {{ 'player.profile.proofs.back_to_games'|trans }}
            </a>
        </div>

        <div class="card shadow-sm">
            <div class="card-header">
                <h2 class="h5 mb-0">{{ game.name }}</h2>
            </div>
            <div class="card-body">
                {% if groupedByGroup is empty %}
                    <p class="text-muted text-center py-4 mb-0">{{ 'player.profile.proofs.no_scores_for_game'|trans }}</p>
                {% elseif groupedByGroup|length == 1 %}
                    {# Single group: display directly without nav-pills #}
                    {% set entry = groupedByGroup|first %}
                    {% include '@VideoGamesRecordsProof/player/profile/_proofs_group_table.html.twig' with {playerCharts: entry.playerCharts} %}
                {% else %}
                    {# Multiple groups: nav-pills #}
                    <ul class="nav nav-pills mb-3" role="tablist">
                        {% for entry in groupedByGroup %}
                            <li class="nav-item" role="presentation">
                                <button
                                    class="nav-link {{ loop.first ? 'active' : '' }}"
                                    id="group-tab-{{ entry.group.id }}"
                                    data-bs-toggle="pill"
                                    data-bs-target="#group-pane-{{ entry.group.id }}"
                                    type="button"
                                    role="tab"
                                    aria-controls="group-pane-{{ entry.group.id }}"
                                    aria-selected="{{ loop.first ? 'true' : 'false' }}"
                                >{{ entry.group.name }}</button>
                            </li>
                        {% endfor %}
                    </ul>

                    <div class="tab-content">
                        {% for entry in groupedByGroup %}
                            <div
                                class="tab-pane fade {{ loop.first ? 'show active' : '' }}"
                                id="group-pane-{{ entry.group.id }}"
                                role="tabpanel"
                                aria-labelledby="group-tab-{{ entry.group.id }}"
                            >
                                {% include '@VideoGamesRecordsProof/player/profile/_proofs_group_table.html.twig' with {playerCharts: entry.playerCharts} %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
