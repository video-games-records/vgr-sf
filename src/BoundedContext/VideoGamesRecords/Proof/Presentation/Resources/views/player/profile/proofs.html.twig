{% extends '@VideoGamesRecordsCore/player/profile/_base.html.twig' %}
{% trans_default_domain 'VgrCore' %}

{% block profile_content %}
<div class="row">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header">
                <h2 class="h5 mb-0">{{ 'player.profile.proofs.title'|trans }}</h2>
            </div>
            <div class="card-body">
                {% if gameStatuses is empty %}
                    <p class="text-muted text-center py-4 mb-0">{{ 'player.profile.proofs.no_proofs'|trans }}</p>
                {% else %}
                    <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-3">
                        {% for entry in gameStatuses %}
                            <div class="col">
                                <a href="{{ path('vgr_player_profile_proofs_game', {id: player.id, slug: player.slug, gameId: entry.game.id, gameSlug: entry.game.slug}) }}" class="text-decoration-none">
                                    <div class="card h-100 border-0 shadow-sm">
                                        <img src="{{ path('vgr_core_game_picture', {id: entry.game.id, v: entry.game.updatedAt|date('U')}) }}"
                                             alt="{{ entry.game.name }}"
                                             loading="lazy"
                                             class="card-img-top object-fit-cover"
                                             style="height: 140px;">
                                        <div class="card-body p-2">
                                            <div class="d-flex flex-wrap gap-1">
                                                {% for status in statuses %}
                                                    {% set count = entry.statuses[status.value] ?? 0 %}
                                                    {% if count > 0 %}
                                                        <span class="d-inline-flex align-items-center gap-1" data-bs-toggle="tooltip" title="{{ status.label }}">
                                                            <span class="proof--{{ status.cssClass }}"></span>
                                                            <small>{{ count }}</small>
                                                        </span>
                                                    {% endif %}
                                                {% endfor %}
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
