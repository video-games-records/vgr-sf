{% extends '@SharedKernel/base.html.twig' %}
{% trans_default_domain 'VgrCore' %}

{% block title %}{{ 'my_proofs.title'|trans }} - Video Games Records{% endblock %}

{% block body %}
<div class="container">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h2 class="h5 mb-0">{{ 'my_proofs.title'|trans }}</h2>
                </div>
                <div class="card-body">
                    {% if gameStatuses is empty %}
                        <p class="text-muted text-center py-4 mb-0">{{ 'my_proofs.no_games'|trans }}</p>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>{{ 'my_proofs.column_game'|trans }}</th>
                                        <th>{{ 'my_proofs.column_statuses'|trans }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for entry in gameStatuses %}
                                        <tr>
                                            <td>
                                                <a href="{{ path('vgr_my_proofs_game', {gameId: entry.game.id, gameSlug: entry.game.slug}) }}" class="text-decoration-none">
                                                    {{ entry.game.name }}
                                                </a>
                                            </td>
                                            <td>
                                                <div class="d-flex flex-wrap gap-2">
                                                    {% for status in statuses %}
                                                        {% set count = entry.statuses[status.value] ?? 0 %}
                                                        {% if count > 0 %}
                                                            <span class="d-inline-flex align-items-center gap-1" data-bs-toggle="tooltip" title="{{ status.label }}">
                                                                <span class="proof--{{ status.cssClass }}"></span>
                                                                <small>{{ count }}</small>
                                                            </span>
                                                        {% endif %}
                                                    {% endfor %}
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
