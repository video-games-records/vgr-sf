{% trans_default_domain 'VgrCore' %}

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
    {% for pc in playerCharts %}
        <div class="col">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center py-2">
                    <span class="fw-semibold text-truncate me-2">{{ pc.chart.name }}</span>
                    <span class="proof--{{ pc.status.cssClass }}" data-bs-toggle="tooltip" title="{{ pc.status.label }}"></span>
                </div>
                <div class="card-body p-2">
                    <div class="d-flex gap-3 small text-muted mb-2">
                        <span>{{ 'player.profile.proofs.column_score'|trans }}: <strong class="text-body">{{ pc.valuesAsString }}</strong></span>
                        <span>{{ 'player.profile.proofs.column_rank'|trans }}: <strong class="text-body">{{ pc.rank }}</strong></span>
                    </div>
                    {% if pc.proof %}
                        <twig:proof_display :proof="pc.proof" />
                    {% endif %}
                </div>
            </div>
        </div>
    {% endfor %}
</div>
