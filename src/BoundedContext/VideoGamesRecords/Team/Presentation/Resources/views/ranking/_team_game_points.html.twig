{% trans_default_domain 'VgrCore' %}

<div class="table-responsive">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th class="text-center" style="width: 60px;">{{ 'leaderboard.columns.rank'|trans }}</th>
                <th>{{ 'leaderboard.columns.team'|trans }}</th>
                <th class="text-end" style="width: 120px;">{{ 'leaderboard.columns.points'|trans }}</th>
                <th class="text-center" style="width: 50px;"></th>
            </tr>
        </thead>
        <tbody>
            {% for teamGame in teamRanking %}
                <tr>
                    <td class="text-center align-middle">
                        <span class="badge rounded-pill {% if loop.index <= 3 %}bg-warning text-dark{% else %}bg-secondary{% endif %}">
                            {{ teamGame.rankPointChart }}
                        </span>
                    </td>
                    <td class="align-middle">
                        <a href="{{ path('vgr_team_profile_overview', {id: teamGame.team.id, slug: teamGame.team.slug}) }}"
                           class="text-decoration-none{% if loop.index <= 3 %} fw-bold{% endif %}">
                            [{{ teamGame.team.tag }}] {{ teamGame.team.libTeam }}
                        </a>
                    </td>
                    <td class="text-end align-middle {% if loop.index <= 3 %}fw-bold{% endif %}">
                        {{ teamGame.pointChart|number_format(0, '.', ',') }}
                    </td>
                    <td class="text-center align-middle">
                        <button type="button" class="btn btn-sm btn-outline-secondary"
                                onclick="openAjaxModal('{{ path('vgr_game_team_players_ajax', {gameId: gameId, teamId: teamGame.team.id}) }}')"
                                title="{{ 'game.show.rankings.view_team_players'|trans }}">
                            <i class="bi bi-people"></i>
                        </button>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">
                        {{ 'leaderboard.no_teams'|trans }}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
