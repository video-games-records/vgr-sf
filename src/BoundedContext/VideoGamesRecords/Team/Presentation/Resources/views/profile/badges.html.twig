{% extends '@VideoGamesRecordsTeam/profile/_base.html.twig' %}
{% trans_default_domain 'VgrTeam' %}

{% block profile_content %}
<div class="card">
    <div class="card-body">
        <h5 class="card-title mb-3">
            <i class="bi bi-patch-check text-warning"></i>
            {{ 'team.profile.badges.title'|trans }}
            <span class="badge bg-secondary">{{ badgesData|length }}</span>
        </h5>

        {% if badgesData|length > 0 %}
            <div class="d-flex flex-wrap gap-1">
                {% for badge in badgesData %}
                    {% set game = games[badge.badgeId] ?? null %}
                    {% set gameName = game ? game.getName(app.request.locale) : 'Badge' %}
                    <span class="badge-item"
                          data-bs-toggle="tooltip"
                          data-bs-placement="top"
                          title="Master - {{ gameName }} | {{ 'team.profile.badges.value'|trans }}: {{ badge.badgeValue }} | {{ 'team.profile.badges.obtained'|trans }}: {{ badge.createdAt|date('d/m/Y') }}">
                        <img src="/badge/{{ badge.badgeId }}/picture"
                             alt="{{ gameName }}"
                             width="40"
                             height="40"
                             class="border rounded">
                    </span>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center text-muted py-5">
                <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                <p class="mt-3 mb-0">{{ 'team.profile.badges.no_badges'|trans }}</p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
